<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Addresses — Fruitkha</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/user-theme.css">
    <link rel="stylesheet" href="/SHOW.css">
    <% const currentPath='address' ; %>
        <link rel="stylesheet" href="/css/pages/address.css">
</head>

<body>
    <header class="profile-topbar">
        <a href="/"><img src="/img/logo.png" alt="Fruitkha" class="brand-logo"></a>
        <button class="topbar-toggle d-md-none" id="sidebarToggleBtn"><i class="fas fa-bars"></i></button>
    </header>

    <div class="profile-layout">
        <%- include('../partials/profileSIDEBAR.ejs') %>
            <%- include('../partials/block.ejs') %>

                <main class="page-content">
                    <div class="content-card">
                        <div class="page-header">
                            <div class="page-header-icon"><i class="fas fa-map-marker-alt"></i></div>
                            <div>
                                <h5 class="ph-title">My Addresses</h5>
                                <span class="ph-sub">Manage your delivery addresses</span>
                            </div>
                            <button class="btn-orange ms-auto" style="font-size:13px;padding:8px 18px;"
                                data-bs-toggle="modal" data-bs-target="#addAddressModal">
                                <i class="fas fa-plus me-1"></i> Add Address
                            </button>
                        </div>

                        <% if (!addres || addres.length===0) { %>
                            <div class="empty-address">
                                <i class="fas fa-map-marked-alt"></i>
                                <p style="color:var(--fr-muted);">No addresses saved yet.</p>
                                <button class="btn-orange mt-2" data-bs-toggle="modal"
                                    data-bs-target="#addAddressModal">
                                    <i class="fas fa-plus me-1"></i> Add Your First Address
                                </button>
                            </div>
                            <% } else { %>
                                <div class="row g-4">
                                    <% addres.forEach(item=>{ %>
                                        <div class="col-md-6">
                                            <div class="address-card">
                                                <span class="address-type-badge"><i class="fas fa-tag me-1"></i>
                                                    <%= item.Address_name %>
                                                </span>
                                                <div class="addr-name">
                                                    <%= item.Name %>
                                                </div>
                                                <div class="addr-line"><i class="fas fa-city"></i>
                                                    <%= item.District %>, <%= item.State %>
                                                </div>
                                                <div class="addr-line"><i class="fas fa-location-arrow"></i>
                                                    <%= item.place %>
                                                </div>
                                                <div class="addr-line"><i class="fas fa-mail-bulk"></i>PIN: <%= item.PIN
                                                        %>
                                                </div>
                                                <div class="addr-line"><i class="fas fa-map-pin"></i>Landmark: <%=
                                                        item.mark %>
                                                </div>
                                                <div class="address-actions">
                                                    <button class="btn-orange" style="font-size:12px;padding:7px 14px;"
                                                        data-bs-toggle="modal" data-bs-target="#editAddressModal"
                                                        onclick="editAddress('<%= item.Address_name %>','<%= item.Name %>','<%= item.State %>','<%= item.District %>','<%= item.place %>','<%= item.PIN %>','<%= item.mark %>','<%= item.id %>')">
                                                        <i class="fas fa-pencil-alt me-1"></i> Edit
                                                    </button>
                                                    <button class="btn-outline-orange"
                                                        style="font-size:12px;padding:7px 14px;border-radius:8px;border:2px solid var(--fr-orange);color:var(--fr-orange);background:transparent;cursor:pointer;transition:all .25s;"
                                                        onclick="deleteAddress('<%= item.id %>')"
                                                        onmouseover="this.style.background='var(--fr-orange)';this.style.color='#fff'"
                                                        onmouseout="this.style.background='transparent';this.style.color='var(--fr-orange)'">
                                                        <i class="fas fa-trash-alt me-1"></i> Delete
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                                <% } %>
                    </div>
                </main>
    </div>

    <!-- Add Address Modal -->
    <div class="modal fade" id="addAddressModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:var(--fr-radius);border:none;">
                <div class="modal-header"
                    style="background:var(--fr-orange-light);border-bottom:1px solid var(--fr-border);">
                    <h5 class="modal-title" style="color:var(--fr-orange);font-weight:700;"><i
                            class="fas fa-plus me-2"></i>Add Address</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="address-form">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Address Name</label>
                                <input type="text" class="form-control" id="addressName"
                                    placeholder="e.g. Home, Office">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Full Name</label>
                                <input type="text" class="form-control" id="NAME" placeholder="Recipient name">
                            </div>
                            <div class="col-6">
                                <label class="form-label">Pincode</label>
                                <input type="text" class="form-control" id="pincode" placeholder="Enter pincode">
                            </div>
                            <div class="col-6">
                                <label class="form-label">Place</label>
                                <select id="place" class="form-control">
                                    <option value="">Select Place</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Landmark</label>
                                <input type="text" class="form-control" id="landmark" placeholder="Nearby landmark">
                            </div>
                            <div class="col-6">
                                <label class="form-label">District</label>
                                <input type="text" class="form-control" id="city" placeholder="District">
                            </div>
                            <div class="col-6">
                                <label class="form-label">State</label>
                                <input type="text" class="form-control" id="state" placeholder="State">
                                <input type="hidden" id="user" value="<%= user %>">
                            </div>
                            <div id="validationResult" class="col-12"></div>
                        </div>
                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn-orange" style="border:none;"><i
                                    class="fas fa-save me-1"></i>Save Address</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Address Modal -->
    <div class="modal fade" id="editAddressModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:var(--fr-radius);border:none;">
                <div class="modal-header"
                    style="background:var(--fr-orange-light);border-bottom:1px solid var(--fr-border);">
                    <h5 class="modal-title" style="color:var(--fr-orange);font-weight:700;"><i
                            class="fas fa-pencil-alt me-2"></i>Edit Address</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="edit-address-form">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Address Name</label>
                                <input type="text" class="form-control" id="editAddressName"
                                    placeholder="Home or Office" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Full Name</label>
                                <input type="text" class="form-control" id="editCustomerName"
                                    placeholder="Recipient name" required>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Pincode</label>
                                <input type="text" class="form-control" id="editPincode" placeholder="Pincode" required>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Place</label>
                                <input type="text" class="form-control" id="editPlace" placeholder="Place">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Landmark</label>
                                <input type="text" class="form-control" id="editLandmark" placeholder="Landmark"
                                    required>
                            </div>
                            <div class="col-6">
                                <label class="form-label">District</label>
                                <input type="text" class="form-control" id="editCity" placeholder="District" required>
                            </div>
                            <div class="col-6">
                                <label class="form-label">State</label>
                                <input type="text" class="form-control" id="editState" placeholder="State" required>
                            </div>
                            <div id="Result" class="col-12"></div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"
                        style="border-radius:8px;">Cancel</button>
                    <button type="submit" form="edit-address-form" class="btn-orange" style="border:none;"><i
                            class="fas fa-save me-1"></i>Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <script src="/TOAST.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script src="/js/addressEjs.js"></script>
    <script>
        const sidebarToggleBtn = document.getElementById('sidebarToggleBtn');
        const userSidebar = document.getElementById('userSidebar');
        if (sidebarToggleBtn && userSidebar)
            sidebarToggleBtn.addEventListener('click', () => userSidebar.classList.toggle('collapsed'));
    </script>
</body>

</html>