<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="description" content="Checkout — Fruitkha">
	<title>Checkout — Fruitkha</title>

	<link rel="shortcut icon" type="image/png" href="/img/favicon.png">
	<link
		href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@400;500;600;700&display=swap"
		rel="stylesheet">
	<link href="/css/all.min.css" rel="stylesheet">
	<link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
	<link rel="stylesheet" href="/css/pages/checkout.css">
	<link rel="stylesheet" href="/SHOW.css">
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>

	<%- include('../partials/Header.ejs') %>
		<%- include('../partials/block.ejs') %>

			<!-- ── Hero Strip ── -->
			<div class="co-hero">
				<div class="co-hero-inner">
					<h1><i class="fas fa-shopping-bag" style="color:var(--orange)"></i> Checkout</h1>
					<div class="co-breadcrumb">
						<a href="/">Home</a>
						<i class="fas fa-chevron-right"></i>
						<a href="/cart">Cart</a>
						<i class="fas fa-chevron-right"></i>
						<span>Checkout</span>
					</div>
				</div>
			</div>

			<!-- ── Main Page ── -->
			<div class="co-page">
				<form action="" id="order-form">
					<div class="co-grid">

						<!-- LEFT COLUMN -->
						<div>

							<!-- Step 1: Delivery Address -->
							<div class="co-section">
								<div class="co-section-title">
									<span class="step-badge">1</span>
									<i class="fas fa-map-marker-alt"></i> Delivery Address
								</div>

								<% if (address && address.length> 0) { %>
									<div class="addr-grid">
										<% address.forEach((item, idx)=> { %>
											<div>
												<label class="addr-label">
													<input type="radio" name="selectedAddress" id="addresId"
														value="<%= item._id %>" <%=idx===0 ? 'checked' : '' %>>
													<div class="addr-card">
														<div class="selected-check"><i class="fas fa-check"></i></div>
														<span class="addr-type">
															<%= item.Address_name %>
														</span>
														<div class="addr-name">
															<%= item.Name %>
														</div>
														<div class="addr-line"><i class="fas fa-city"></i>
															<%= item.District %>, <%= item.State %>
														</div>
														<div class="addr-line"><i class="fas fa-location-arrow"></i>
															<%= item.place %>
														</div>
														<div class="addr-line"><i class="fas fa-mail-bulk"></i> PIN: <%=
																item.PIN %>
														</div>
														<% if (item.mark) { %>
															<div class="addr-line"><i class="fas fa-map-pin"></i>
																<%= item.mark %>
															</div>
															<% } %>
																<button type="button" class="btn-edit-addr"
																	data-bs-toggle="modal"
																	data-bs-target="#editAddressModal"
																	onclick="editAddress('<%= item.Address_name %>','<%= item.Name %>','<%= item.State %>','<%= item.District %>','<%= item.place %>','<%= item.PIN %>','<%= item.mark %>','<%= item.id %>')">
																	<i class="fas fa-pencil-alt"></i> Edit
																</button>
													</div>
												</label>
											</div>
											<% }) %>
									</div>

									<div class="mt-3">
										<a href="/address" class="btn-add-addr">
											<i class="fas fa-plus"></i> Add New Address
										</a>
									</div>

									<% } else { %>
										<div class="empty-addr">
											<i class="fas fa-map-marked-alt"></i>
											<p>No addresses saved yet.</p>
											<a href="/address" class="btn-add-addr"><i class="fas fa-plus"></i> Add
												Address</a>
										</div>
										<% } %>
							</div>

							<!-- Step 2: Payment Method -->
							<div class="co-section">
								<div class="co-section-title">
									<span class="step-badge">2</span>
									<i class="fas fa-credit-card"></i> Payment Method
								</div>

								<div class="pay-grid">

									<!-- Razorpay -->
									<label class="pay-label">
										<input type="radio" name="paymentMethod" id="razorpay" value="razorpay">
										<div class="pay-card">
											<div class="pay-icon-wrap pay-icon-razorpay"><i class="fas fa-bolt"></i>
											</div>
											<div class="pay-info">
												<div class="pay-title">Online Payment</div>
												<div class="pay-sub">Credit/Debit Card, UPI, Net Banking via Razorpay
												</div>
											</div>
											<div class="pay-radio-dot"></div>
										</div>
									</label>

									<!-- Wallet -->
									<label class="pay-label">
										<input type="radio" name="paymentMethod" id="WALLET" value="wallet">
										<div class="pay-card">
											<div class="pay-icon-wrap pay-icon-wallet"><i class="fas fa-wallet"></i>
											</div>
											<div class="pay-info">
												<div class="pay-title">Pay with Wallet</div>
												<div class="pay-sub">Use your Fruitkha wallet balance instantly</div>
											</div>
											<div class="pay-radio-dot"></div>
										</div>
									</label>

									<!-- COD -->
									<label class="pay-label">
										<input type="radio" name="paymentMethod" id="cod" value="COD">
										<div class="pay-card" id="CODinf">
											<div class="pay-icon-wrap pay-icon-cod"><i
													class="fas fa-money-bill-wave"></i></div>
											<div class="pay-info">
												<div class="pay-title">Cash on Delivery</div>
												<div class="pay-sub">Pay when your order arrives at your door</div>
												<p id="inform" class="cod-warn d-none"></p>
											</div>
											<div class="pay-radio-dot"></div>
										</div>
									</label>

								</div>
							</div>

						</div><!-- /LEFT COLUMN -->

						<!-- RIGHT: Order Summary -->
						<div>
							<div class="order-summary-card">
								<div class="os-title"><i class="fas fa-receipt"></i> Order Summary</div>

								<!-- Items -->
								<% cart.Products.forEach(item=> { %>
									<div class="os-item">
										<input type="text" value="<%= cart.UserID %>" hidden>
										<div class="os-item-name">
											<%= item.productId.productTitle %>
												<span class="os-item-qty d-block">Qty: <%= item.quantity %> kg</span>
										</div>
										<div class="os-item-price">₹<%= item.TOTAL %>
										</div>
									</div>
									<% }) %>

										<hr class="os-divider">

										<!-- Totals -->
										<% let gst=(0.12 * cart.subTotal); %>
											<div class="os-row"><span class="label">Subtotal</span><span class="value">₹
													<%= cart.subTotal.toFixed(2) %></span></div>
											<div class="os-row"><span class="label">GST (12%)</span><span
													class="value">₹<%= gst.toFixed(2) %></span></div>
											<div class="os-row os-discount">
												<span class="label">Discount</span>
												<span class="value">−₹<%= cart.Discount.discount_amount.toFixed(2) %>
														</span>
											</div>
											<div class="os-row"><span class="label">Shipping</span><span class="value">₹
													<%= cart.Shipping.toFixed(2) %></span></div>
											<div class="os-row os-total">
												<span>Total</span>
												<span class="value">₹<%= (cart.subTotal + gst + cart.Shipping -
														cart.Discount.discount_amount).toFixed(2) %></span>
											</div>

											<!-- Coupon -->
											<fieldset id="innerForm">
												<div class="coupon-wrap">
													<div class="coupon-label"><i class="fas fa-tag me-2"></i>Have a
														coupon?</div>
													<% if (!cart.Discount.discount_amount> 0) { %>
														<div class="coupon-input-row">
															<input type="text" id="coupon-input"
																placeholder="Enter coupon code">
															<button type="button" data-total="<%= cart.subTotal %>"
																data-user="<%= user %>" id="apply">Apply</button>
														</div>
														<% } else { %>
															<button type="button"
																data-coupon="<%= cart.Discount.discountId %>"
																data-user="<%= user %>" id="remove">
																<i class="fas fa-times-circle me-2"></i>Remove Coupon
															</button>
															<% } %>
																<p id="result"
																	style="color:red;font-size:12px;margin-top:6px;">
																</p>
												</div>
											</fieldset>

											<!-- Place Order -->
											<button type="submit"
												data-amount="<%= (cart.subTotal + gst + cart.Shipping - cart.Discount.discount_amount) %>"
												id="place" class="btn-place-order">
												<i class="fas fa-lock"></i> Place Order
											</button>
											<div class="secure-note">
												<i class="fas fa-shield-alt"></i> Secure &amp; encrypted checkout
											</div>
							</div>
						</div>

					</div><!-- /co-grid -->
				</form>
			</div><!-- /co-page -->

			<!-- Edit Address Modal -->
			<div class="modal fade" id="editAddressModal" tabindex="-1" aria-hidden="true">
				<div class="modal-dialog modal-dialog-centered">
					<div class="modal-content" style="border-radius:14px;border:none;">
						<div class="modal-header" style="background:#fff4ea;border-bottom:1px solid #e2e8f0;">
							<h5 class="modal-title"
								style="color:var(--orange);font-weight:700;font-family:'Poppins',sans-serif;">
								<i class="fas fa-pencil-alt me-2"></i>Edit Address
							</h5>
							<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
						</div>
						<div class="modal-body">
							<form id="edit-address-form">
								<div class="row g-3">
									<div class="col-12">
										<label class="form-label fw-600">Address Name</label>
										<input type="text" class="form-control" id="editAddressName"
											placeholder="Home or Office" required>
									</div>
									<div class="col-12">
										<label class="form-label fw-600">Full Name</label>
										<input type="text" class="form-control" id="editCustomerName"
											placeholder="Recipient name" required>
									</div>
									<div class="col-6">
										<label class="form-label">Pincode</label>
										<input type="text" class="form-control" id="editPincode"
											placeholder="Enter Pincode" required>
									</div>
									<div class="col-6">
										<label class="form-label">Place</label>
										<input type="text" id="editPlace" class="form-control" placeholder="Place">
									</div>
									<div class="col-12">
										<label class="form-label">Landmark</label>
										<input type="text" class="form-control" id="editLandmark"
											placeholder="Enter Landmark" required>
									</div>
									<div class="col-6">
										<label class="form-label">District</label>
										<input type="text" class="form-control" id="editCity" placeholder="District"
											required>
									</div>
									<div class="col-6">
										<label class="form-label">State</label>
										<input type="text" class="form-control" id="editState" placeholder="State"
											required>
									</div>
								</div>
								<div id="Result" class="mt-3"></div>
							</form>
						</div>
						<div class="modal-footer">
							<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"
								style="border-radius:8px;">Cancel</button>
							<button type="submit" form="edit-address-form" class="btn"
								style="background:var(--orange);color:#fff;border-radius:8px;font-weight:600;">
								<i class="fas fa-save me-1"></i>Save Changes
							</button>
						</div>
					</div>
				</div>
			</div>

			<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
			<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
			<script src="/TOAST.js"></script>
			<script src="/js/checkoutEjs.js"></script>
</body>

</html>