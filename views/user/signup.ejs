<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fruitkha - Sign Up</title>
    <link rel="stylesheet" href="/toast.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/css/pages/signup.css">
</head>

<body>
    <div class="toast-container" id="toastContainer"></div>
    <div class="container">
        <div class="logo-container">
            <img src="/img/logo.png" alt="Fruitkha Logo" width="250">

        </div>

        <form id="signupForm" class="signup-form" action="/signup" method="post">
            <h2 style="font-weight: 200; color: #575757;">Sign up</h2>

            <div class="name-group">
                <div class="form-group">
                    <input id="firstName" type="text" name="firstName" placeholder="First Name">
                    <span style="color: #ff1a1a; font-size: 12px;" class="error" id="firstNameerror"></span>

                </div>
                <div class="form-group">
                    <input id="lastName" type="text" name="lastName" placeholder="Last Name">
                    <span style="color: #ff1a1a; font-size: 12px;" class="error" id="lasterror"></span>
                </div>
            </div>

            <div class="form-group">
                <input id="email" type="email" name="email" placeholder="Email">
                <span style="color: #ff1a1a; font-size: 12px;" class="error" id="EMIALerror"></span>
            </div>

            <div class="form-group">
                <input id="phone" type="tel" name="phone" placeholder="Phone">
                <span style="color: #ff1a1a; font-size: 12px;" class=" error" id="PHONEerror"></span>
            </div>

            <div class="form-group">
                <input id="password" type="password" name="password" placeholder="Password">
                <span class="error" style="color: #ff1a1a; font-size: 12px;" id="Passworderror"></span>
            </div>

            <div class="form-group">
                <input id="confirmPassword" type="password" name="confirmPassword" placeholder="Confirm Password">
                <span class="error" style="color: #ff1a1a; font-size: 12px;" id="Confirmerror"></span>
            </div>
            <div>
                <h4 id="result" style="color: #ff1a1a; font-size: 12px;" class=""></h4>

            </div>


            <button type="submit" class="signup-btn">Sign up</button>

            <p class="login-link">
                Already have an account? <a href="/login">Sign in</a>
            </p>

            <a style="text-decoration: none;" href="/auth/google" class="google-btn">
                <img src="/img/icons8-google-logo-96.png" alt="Google Icon" width="20">
                Sign in with Google
            </a>

            <!-- <% if (locals.error) { %>
                <div class="error-message">
                    <%= error %>
                </div>
            <% } %> -->
        </form>
        <script src="/showNotification.js"></script>
        <script src="/js/signup.js"></script>
    </div>
</body>

</html>