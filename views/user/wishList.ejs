<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wishlist — Fruitkha</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/user-theme.css">
    <link rel="stylesheet" href="/SHOW.css">
    <% const currentPath='wishList' ; %>
        <link rel="stylesheet" href="/css/pages/wishlist.css">

</head>

<body>
    <header class="profile-topbar">
        <a href="/"><img src="/img/logo.png" alt="Fruitkha" class="brand-logo"></a>
        <button class="topbar-toggle d-md-none" id="sidebarToggleBtn"><i class="fas fa-bars"></i></button>
    </header>

    <div class="profile-layout">
        <%- include('../partials/profileSIDEBAR.ejs') %>

            <main class="page-content">
                <div class="content-card">
                    <div class="page-header">
                        <div class="page-header-icon"><i class="fas fa-heart"></i></div>
                        <div>
                            <h5 class="ph-title">My Wishlist</h5>
                            <span class="ph-sub">Items you've saved for later</span>
                        </div>
                    </div>

                    <% if (!wish || !wish.Products || wish.Products.length===0) { %>
                        <div class="empty-wishlist">
                            <i class="fas fa-heart-broken"></i>
                            <p>
                                <%= typeof info !=='undefined' ? info : 'Your wishlist is empty.' %>
                            </p>
                            <a href="/shop" class="btn-orange mt-3"><i class="fas fa-store me-2"></i>Browse Products</a>
                        </div>
                        <% } else { %>
                            <% wish.Products.forEach(item=> { %>
                                <div class="wish-item">
                                    <% if (item.product.primaryImage) { %>
                                        <img src="<%= item.product.primaryImage %>" class="wish-img"
                                            alt="<%= item.product.productTitle %>">
                                        <% } else { %>
                                            <div class="wish-img-placeholder"><i class="fas fa-image"></i></div>
                                            <% } %>

                                                <div class="wish-info">
                                                    <div class="wish-title">
                                                        <%= item.product.productTitle %>
                                                    </div>

                                                    <% if (item.product.OfferPrice) { %>
                                                        <div class="wish-price-offer">₹<%= item.product.OfferPrice %>
                                                                <span style="font-size:11px;font-weight:400"> /
                                                                    kg</span></div>
                                                        <div class="wish-price-regular"><del>₹<%=
                                                                    item.product.RegulerPrice %></del> <span
                                                                style="font-size:11px">regular</span></div>
                                                        <% } else { %>
                                                            <div class="wish-price-offer">₹<%= item.product.RegulerPrice
                                                                    %> <span style="font-size:11px;font-weight:400"> /
                                                                        kg</span></div>
                                                            <% } %>

                                                                <div class="wish-desc">
                                                                    <%= item.product.description ?
                                                                        item.product.description.substring(0,70) + '...'
                                                                        : '' %>
                                                                </div>

                                                                <% if (item.product.Stock> 10) { %>
                                                                    <span class="stock-badge stock-in"><i
                                                                            class="fas fa-check-circle me-1"></i>In
                                                                        Stock (<%= item.product.Stock %>)</span>
                                                                    <% } else if (item.product.Stock> 0) { %>
                                                                        <span class="stock-badge stock-low"><i
                                                                                class="fas fa-exclamation-circle me-1"></i>Low
                                                                            Stock (<%= item.product.Stock %>)</span>
                                                                        <% } else { %>
                                                                            <span class="stock-badge stock-out"><i
                                                                                    class="fas fa-times-circle me-1"></i>Out
                                                                                of Stock</span>
                                                                            <% } %>
                                                </div>

                                                <div class="wish-actions">
                                                    <button class="btn-orange" style="font-size:13px;padding:8px 18px;"
                                                        onclick="addToCart('<%= item.product._id %>')">
                                                        <i class="fas fa-cart-plus"></i> Add to Cart
                                                    </button>
                                                    <button class="btn-outline-orange"
                                                        style="font-size:13px;padding:8px 18px;border-radius:8px;"
                                                        onclick="remove('<%= item.product._id %>','<%= item._id %>')">
                                                        <i class="fas fa-trash-alt"></i> Remove
                                                    </button>
                                                </div>
                                </div>
                                <% }) %>
                                    <% } %>

                </div>
            </main>
    </div>

    <%- include('../partials/block.ejs') %>
        <div class="toast-container" id="toastContainer"></div>
        <script src="/showNotification.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
        <script>
            const sidebarToggleBtn = document.getElementById('sidebarToggleBtn');
            const userSidebar = document.getElementById('userSidebar');
            if (sidebarToggleBtn && userSidebar)
                sidebarToggleBtn.addEventListener('click', () => userSidebar.classList.toggle('collapsed'));

            function remove(productId, item) {
                fetch(`/api/wishlist/items/${item}`, { method: 'DELETE' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) location.reload();
                        else showToast(data.message, 'error');
                    })
                    .catch(err => console.error(err));
            }

            function addToCart(productId) {
                // hook into your existing cart logic if present
                console.log('Add to cart:', productId);
            }
        </script>
</body>

</html>