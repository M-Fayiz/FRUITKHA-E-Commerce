<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Fruitkha cart">
  <title>Cart</title>

  <link rel="stylesheet" href="/SHOW.css">
  <link rel="shortcut icon" type="image/png" href="/img/favicon.png">
  <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,700" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css?family=Poppins:400,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/all.min.css">
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/owl.carousel.css">
  <link rel="stylesheet" href="/css/magnific-popup.css">
  <link rel="stylesheet" href="/css/animate.css">
  <link rel="stylesheet" href="/css/meanmenu.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">

  <style>
    :root {
      --cart-accent: #f97316;
      --cart-bg: #f6f8fc;
      --cart-panel: #ffffff;
      --cart-border: #e2e8f0;
      --cart-text: #0f172a;
      --cart-muted: #64748b;
      --cart-danger: #dc2626;
    }

    body {
      background: radial-gradient(circle at top right, #fff1e5, #f6f8fc 46%);
    }

    .breadcrumb-section.breadcrumb-bg {
      background: #fff7ef !important;
      min-height: auto !important;
      padding: 40px 0 28px !important;
      margin-bottom: 12px;
    }

    .breadcrumb-text p {
      margin-bottom: 4px !important;
      font-size: 13px !important;
      letter-spacing: 0.08em !important;
    }

    .breadcrumb-text h1 {
      font-size: 34px !important;
      line-height: 1.1 !important;
      margin: 0 !important;
    }

    .cart-shell {
      padding: 20px 0 80px;
      min-height: 70vh;
    }

    .cart-top {
      background: linear-gradient(120deg, #ffffff, #fff5eb);
      border: 1px solid #f7ddc4;
      border-radius: 18px;
      padding: 30px;
      margin-bottom: 18px;
      box-shadow: 0 12px 26px rgba(15, 23, 42, 0.07);
    }

    .cart-top h1 {
      margin: 0;
      font-size: 34px;
      color: var(--cart-text);
    }

    .cart-top p {
      margin: 7px 0 0;
      color: var(--cart-muted);
    }

    .cart-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 320px;
      gap: 18px;
      align-items: start;
    }

    .cart-panel {
      background: var(--cart-panel);
      border: 1px solid var(--cart-border);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
    }

    .cart-table-wrap {
      overflow-x: auto;
    }

    .cart-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 760px;
    }

    .cart-table thead tr {
      background: #f8fafc;
      border-bottom: 1px solid var(--cart-border);
    }

    .cart-table th,
    .cart-table td {
      padding: 14px;
      text-align: left;
      vertical-align: middle;
      color: var(--cart-text);
    }

    .cart-table tbody tr {
      border-bottom: 1px solid var(--cart-border);
    }

    .item-cell {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 240px;
    }

    .item-thumb {
      width: 68px;
      height: 68px;
      border-radius: 12px;
      object-fit: cover;
      border: 1px solid #e8edf5;
      background: #f1f5f9;
    }

    .item-name {
      margin: 0;
      font-size: 15px;
      font-weight: 700;
      line-height: 1.3;
    }

    .item-price {
      margin: 2px 0 0;
      font-size: 13px;
      color: var(--cart-muted);
    }

    .qty-control {
      display: inline-flex;
      align-items: center;
      border: 1px solid #d8e2ed;
      border-radius: 10px;
      overflow: hidden;
      height: 38px;
      background: #fff;
    }

    .qty-btn {
      width: 36px;
      height: 38px;
      border: 0;
      background: #f8fafc;
      font-weight: 700;
      color: #0f172a;
      transition: 0.2s ease;
    }

    .qty-btn:hover {
      background: #eef2f7;
    }

    .qty-btn:disabled {
      color: #9ca3af;
      cursor: not-allowed;
    }

    .qty-input {
      width: 46px;
      text-align: center;
      border: 0;
      color: #0f172a;
      font-weight: 700;
      font-size: 14px;
      background: #fff;
    }

    .remove-item-btn {
      border: 0;
      border-radius: 8px;
      height: 34px;
      width: 34px;
      background: #fee2e2;
      color: var(--cart-danger);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .summary-panel {
      background: var(--cart-panel);
      border: 1px solid var(--cart-border);
      border-radius: 16px;
      padding: 18px;
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
      position: sticky;
      top: 90px;
    }

    .summary-title {
      margin: 0 0 14px;
      font-size: 19px;
      color: #0f172a;
      font-weight: 700;
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
      border-bottom: 1px solid #edf2f7;
      color: #334155;
      font-weight: 600;
    }

    .summary-row.total {
      border-bottom: 0;
      font-size: 20px;
      color: #0f172a;
      padding-top: 14px;
      font-weight: 700;
    }

    .checkout-btn {
      margin-top: 16px;
      width: 100%;
      height: 46px;
      border: 0;
      border-radius: 10px;
      background: var(--cart-accent);
      color: #fff;
      font-weight: 700;
      text-decoration: none;
      display: inline-flex;
      justify-content: center;
      align-items: center;
    }

    .empty-state {
      text-align: center;
      padding: 46px 20px;
      color: #334155;
    }

    .empty-state i {
      font-size: 38px;
      color: #94a3b8;
      margin-bottom: 12px;
      display: inline-block;
    }

    .empty-state h2 {
      margin: 0 0 8px;
      color: #0f172a;
      font-size: 24px;
    }

    .empty-state p {
      margin: 0 0 18px;
      color: #64748b;
    }

    .empty-state a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      height: 44px;
      padding: 0 20px;
      background: var(--cart-accent);
      color: #fff;
      text-decoration: none;
      font-weight: 700;
    }

    @media (max-width: 991px) {
      .cart-grid {
        grid-template-columns: 1fr;
      }

      .summary-panel {
        position: static;
      }
    }
  </style>
</head>
<body>
  <%- include('../partials/Header.ejs') %>
  <%- include('../partials/block.ejs') %>

  <div class="search-area">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <span class="close-btn"><i class="fas fa-window-close"></i></span>
          <div class="search-bar">
            <div class="search-bar-tablecell">
              <h3>Search For:</h3>
              <input type="text" placeholder="Keywords">
              <button type="submit">Search <i class="fas fa-search"></i></button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="breadcrumb-section breadcrumb-bg">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 offset-lg-2 text-center">
          <div class="breadcrumb-text">
         
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="cart-shell">
    <div class="container">
      <div class="cart-top">
        <h1>Shopping Cart</h1>
        <p>Review your items, adjust quantities, and proceed when ready.</p>
      </div>

      <% const hasItems = data && data.Products && data.Products.length > 0; %>

      <% if (!hasItems) { %>
        <div class="cart-panel empty-state" id="emptyState">
          <i class="fas fa-shopping-basket"></i>
          <h2>Your cart is empty</h2>
          <p><%= info || 'No items in your cart.' %></p>
          <a href="/shop">Continue Shopping</a>
        </div>
      <% } else { %>
        <div class="cart-grid" id="cartContent">
          <div class="cart-panel cart-table-wrap" id="cartTableWrap">
            <table class="cart-table">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Unit Price</th>
                  <th>Quantity</th>
                  <th>Subtotal</th>
                  <th>Remove</th>
                </tr>
              </thead>
              <tbody id="cartRows">
                <% data.Products.forEach(function(item) { %>
                  <% const unitPrice = item.Price; %>
                  <tr id="cart-row-<%= item.productId.id %>">
                    <td>
                      <div class="item-cell">
                        <img class="item-thumb" src="/images/<%= item.productId.primaryImage %>" alt="<%= item.productId.productTitle %>">
                        <div>
                          <h3 class="item-name"><%= item.productId.productTitle %></h3>
                          <p class="item-price">
                            <% if (item.productId.Offer && item.productId.Offer.OfferPrice > 0) { %>
                              Offer &#8377;<%= item.productId.Offer.OfferPrice %> | MRP &#8377;<%= item.productId.RegulerPrice %>
                            <% } else { %>
                              Regular &#8377;<%= item.productId.RegulerPrice %>
                            <% } %>
                          </p>
                        </div>
                      </div>
                    </td>
                    <td>
                      <strong>&#8377;<%= unitPrice %></strong>
                    </td>
                    <td>
                      <div class="qty-control">
                        <button class="qty-btn dec-button" data-action="decrease" data-id="<%= item.productId.id %>" id="dec-<%= item.productId.id %>" <%= item.quantity <= 1 ? 'disabled' : '' %>>-</button>
                        <input class="qty-input quantity-input" id="quantity-<%= item.productId.id %>" type="number" value="<%= item.quantity %>" min="1" readonly>
                        <button class="qty-btn inc-button" data-action="increase" data-id="<%= item.productId.id %>" id="inc-<%= item.productId.id %>">+</button>
                      </div>
                    </td>
                    <td>
                      <strong id="subtotal-<%= item.productId.id %>" data-row-total-value="<%= item.quantity * unitPrice %>">&#8377;<%= item.quantity * unitPrice %></strong>
                    </td>
                    <td>
                      <button class="remove-item-btn" data-id="<%= item.productId.id %>" aria-label="Remove item">
                        <i class="far fa-trash-alt"></i>
                      </button>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <aside class="summary-panel" id="totalsPanel">
            <h2 class="summary-title">Order Summary</h2>
            <div class="summary-row">
              <span>Subtotal</span>
              <span id="cart-subtotal">&#8377;<%= data.subTotal || 0 %></span>
            </div>
            <div class="summary-row">
              <span>Delivery</span>
              <span>Calculated at checkout</span>
            </div>
            <div class="summary-row total">
              <span>Total</span>
              <span id="cart-grand-total">&#8377;<%= data.subTotal || 0 %></span>
            </div>
            <a href="/checkout" class="checkout-btn">Proceed to Checkout</a>
          </aside>
        </div>

        <div class="cart-panel empty-state" id="emptyState" style="display:none;">
          <i class="fas fa-shopping-basket"></i>
          <h2>Your cart is empty</h2>
          <p>Items removed from your cart will appear here.</p>
          <a href="/shop">Continue Shopping</a>
        </div>
      <% } %>
    </div>
  </section>

  <script src="/TOAST.js"></script>
  <script src="/js/jquery-1.11.3.min.js"></script>
  <script src="/bootstrap/js/bootstrap.min.js"></script>
  <script src="/js/jquery.countdown.js"></script>
  <script src="/js/jquery.isotope-3.0.6.min.js"></script>
  <script src="/js/waypoints.js"></script>
  <script src="/js/owl.carousel.min.js"></script>
  <script src="/js/jquery.magnific-popup.min.js"></script>
  <script src="/js/jquery.meanmenu.min.js"></script>
  <script src="/js/sticker.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/cartEjs.js"></script>
</body>
</html>
