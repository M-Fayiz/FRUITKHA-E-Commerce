<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Fruitkha cart">
  <title>Cart | Fruitkha</title>

  <link rel="shortcut icon" type="image/png" href="/img/favicon.png">
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@400;500;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/all.min.css">
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/pages/cart.css">
  <link rel="stylesheet" href="/SHOW.css">
</head>

<body>
  <%- include('../partials/Header.ejs') %>
    <%- include('../partials/block.ejs') %>

      <section class="cart-shell">
        <div class="container">
          <div class="cart-top">
            <h1><i class="fas fa-shopping-cart" style="color:var(--p);margin-right:10px;font-size:24px;"></i>Shopping
              Cart</h1>
            <p>Review your items, adjust quantities, and proceed when ready.</p>
          </div>

          <% const hasItems=data && data.Products && data.Products.length> 0; %>

            <% if (!hasItems) { %>
              <div class="cart-panel empty-state" id="emptyState">
                <i class="fas fa-shopping-basket"></i>
                <h2>Your cart is empty</h2>
                <p>
                  <%= info || 'Start adding some fresh products!' %>
                </p>
                <a href="/shop"><i class="fas fa-store"></i> Browse Products</a>
              </div>
              <% } else { %>

                <div class="cart-grid" id="cartContent">

                  <!-- Cart Table -->
                  <div class="cart-panel cart-table-wrap" id="cartTableWrap">
                    <table class="cart-table">
                      <thead>
                        <tr>
                          <th>Product</th>
                          <th>Unit Price</th>
                          <th>Quantity</th>
                          <th>Subtotal</th>
                          <th></th>
                        </tr>
                      </thead>
                      <tbody id="cartRows">
                        <% data.Products.forEach(function(item) { %>
                          <% const unitPrice=item.Price; %>
                            <tr id="cart-row-<%= item.productId.id %>">
                              <td>
                                <div class="item-cell">
                                  <img class="item-thumb" src="<%= item.productId.primaryImage %>"
                                    alt="<%= item.productId.productTitle %>">
                                  <div>
                                    <h3 class="item-name">
                                      <%= item.productId.productTitle %>
                                    </h3>
                                    <p class="item-price">
                                      <% if (item.productId.Offer && item.productId.Offer.OfferPrice> 0) { %>
                                        Offer &#8377;<%= item.productId.Offer.OfferPrice %> &nbsp;|&nbsp; MRP &#8377;<%=
                                            item.productId.RegulerPrice %>
                                            <% } else { %>
                                              Regular &#8377;<%= item.productId.RegulerPrice %>
                                                <% } %>
                                    </p>
                                  </div>
                                </div>
                              </td>
                              <td><strong>&#8377;<%= unitPrice %></strong></td>
                              <td>
                                <div class="qty-control">
                                  <button class="qty-btn dec-button" data-action="decrease"
                                    data-id="<%= item.productId.id %>" id="dec-<%= item.productId.id %>"
                                    <%=item.quantity <=1 ? 'disabled' : '' %>>−</button>
                                  <input class="qty-input quantity-input" id="quantity-<%= item.productId.id %>"
                                    type="number" value="<%= item.quantity %>" min="1" readonly>
                                  <button class="qty-btn inc-button" data-action="increase"
                                    data-id="<%= item.productId.id %>" id="inc-<%= item.productId.id %>">+</button>
                                </div>
                              </td>
                              <td>
                                <strong id="subtotal-<%= item.productId.id %>"
                                  data-row-total-value="<%= item.quantity * unitPrice %>">
                                  &#8377;<%= item.quantity * unitPrice %>
                                </strong>
                              </td>
                              <td>
                                <button class="remove-item-btn" data-id="<%= item.productId.id %>"
                                  aria-label="Remove item">
                                  <i class="far fa-trash-alt"></i>
                                </button>
                              </td>
                            </tr>
                            <% }) %>
                      </tbody>
                    </table>
                  </div>

                  <!-- Order Summary -->
                  <aside class="summary-panel" id="totalsPanel">
                    <h2 class="summary-title"><i class="fas fa-receipt"></i> Order Summary</h2>
                    <div class="summary-row">
                      <span>Subtotal</span>
                      <span id="cart-subtotal">&#8377;<%= data.subTotal || 0 %></span>
                    </div>
                    <div class="summary-row">
                      <span>Delivery</span>
                      <span>Calculated at checkout</span>
                    </div>
                    <div class="summary-row total">
                      <span>Total</span>
                      <span id="cart-grand-total">&#8377;<%= data.subTotal || 0 %></span>
                    </div>
                    <a href="/checkout" class="checkout-btn">
                      <i class="fas fa-lock"></i> Proceed to Checkout
                    </a>
                    <a href="/shop" class="continue-shop">&#8592; Continue Shopping</a>
                  </aside>
                </div>

                <!-- Empty state (shown after removing all items via JS) -->
                <div class="cart-panel empty-state" id="emptyState" style="display:none;">
                  <i class="fas fa-shopping-basket"></i>
                  <h2>Your cart is empty</h2>
                  <p>Items removed from your cart will appear here.</p>
                  <a href="/shop"><i class="fas fa-store"></i> Browse Products</a>
                </div>

                <% } %>
        </div>
      </section>

      <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
      <script src="/TOAST.js"></script>
      <script src="/js/cartEjs.js"></script>
</body>

</html>