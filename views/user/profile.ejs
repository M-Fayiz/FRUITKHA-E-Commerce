<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile — Fruitkha</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
    <!-- Bootstrap -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
    <!-- Fruitkha Shared Theme -->
    <link rel="stylesheet" href="/user-theme.css">
    <link rel="stylesheet" href="/SHOW.css">
    <% const currentPath='profile' ; %>
</head>

<body>

    <!-- ── Top Navigation Bar ── -->
    <header class="profile-topbar">
        <a href="/">
            <img src="/img/logo.png" alt="Fruitkha" class="brand-logo">
        </a>
        <!-- Mobile sidebar toggler -->
        <button class="topbar-toggle d-md-none" id="sidebarToggleBtn" aria-label="Toggle menu">
            <i class="fas fa-bars"></i>
        </button>
    </header>

    <!-- ── Layout ── -->
    <div class="profile-layout">

        <!-- Sidebar -->
        <%- include('../partials/profileSIDEBAR.ejs') %>

            <!-- Main Content -->
            <main class="page-content">

                <!-- ── Profile Details Card ── -->
                <div class="content-card">
                    <div class="page-header">
                        <div class="page-header-icon">
                            <i class="fas fa-user"></i>
                        </div>
                        <div>
                            <h5 class="ph-title">Profile Details</h5>
                            <span class="ph-sub">Manage your personal information</span>
                        </div>
                    </div>

                    <form id="edit-profile">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <input type="text" id="FIRST" value="<%= user.firstName %>" class="form-control"
                                    placeholder="Enter first name">
                                <span id="Firsterror" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Last Name</label>
                                <input type="text" id="LAST" value="<%= user.lastName %>" class="form-control"
                                    placeholder="Enter last name">
                                <span id="Lasterror" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phone Number</label>
                                <input type="tel" id="phone" value="<%= user.phone %>" class="form-control"
                                    placeholder="Enter phone number">
                                <span id="PHONEerror" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email Address</label>
                                <input type="email" value="<%= user.email %>" class="form-control" disabled
                                    style="opacity:0.65; cursor:not-allowed;">
                                <span class="d-block mt-1" style="font-size: 12px; color: var(--fr-muted);">Email cannot
                                    be changed</span>
                            </div>
                        </div>

                        <!-- Hidden user ID -->
                        <input type="hidden" id="ID" value="<%= user.id %>">

                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn-orange">
                                <i class="fas fa-save"></i> Update Profile
                            </button>
                        </div>
                    </form>
                </div>

                <!-- ── Password Settings Card ── -->
                <% if (user.isGoogle===false) { %>
                    <div class="content-card">
                        <div class="page-header">
                            <div class="page-header-icon">
                                <i class="fas fa-lock"></i>
                            </div>
                            <div>
                                <h5 class="ph-title">Password Settings</h5>
                                <span class="ph-sub">Change your account password</span>
                            </div>
                        </div>

                        <form id="pass-form">
                            <input type="hidden" id="userID" value="<%= user.id %>">

                            <div class="row g-4">
                                <div class="col-md-12">
                                    <label class="form-label">Current Password</label>
                                    <input id="password" type="password" class="form-control"
                                        placeholder="Enter current password">
                                    <span id="Passworderror" class="text-danger" style="font-size: 12px;"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">New Password</label>
                                    <input id="PAS1" type="password" class="form-control"
                                        placeholder="Enter new password">
                                    <span id="PAS1error" class="text-danger" style="font-size: 12px;"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Confirm New Password</label>
                                    <input id="PAS2" type="password" class="form-control"
                                        placeholder="Confirm new password">
                                    <span id="PAS2error" class="text-danger" style="font-size: 12px;"></span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-4">
                                <a href="/rest" class="fr-link">
                                    <i class="fas fa-key me-1"></i> Forgot your password?
                                </a>
                                <button type="submit" class="btn-orange">
                                    <i class="fas fa-shield-alt"></i> Change Password
                                </button>
                            </div>
                        </form>
                    </div>
                    <% } %>

            </main>
    </div>

    <%- include('../partials/block.ejs') %>
        <script src="/TOAST.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
        <script src="/js/profileEjs.js"></script>

        <!-- Mobile sidebar toggle -->
        <script>
            const sidebarToggleBtn = document.getElementById('sidebarToggleBtn');
            const userSidebar = document.getElementById('userSidebar');
            if (sidebarToggleBtn && userSidebar) {
                sidebarToggleBtn.addEventListener('click', () => {
                    userSidebar.classList.toggle('collapsed');
                });
            }
        </script>

</body>

</html>