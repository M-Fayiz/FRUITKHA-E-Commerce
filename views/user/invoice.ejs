<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customer Invoice</title>
  <link rel="stylesheet" href="/css/pages/invoice.css">
</head>

<body>
  <div class="invoice-container">
    <div class="header">
      <!-- <img src="/img/logo.png" alt=""> -->
      <h1>FRUITKHA</h1>
      <p>Fresh Fruits Online</p>
    </div>

    <div class="section">
      <h2>Invoice Details</h2>
      <p><strong>Invoice No:</strong>
        <%=value%>
      </p>
      <p><strong>OrderID :</strong>
        <%=order.orderNumber || order.id%>
      </p>
      <p><strong>Date:</strong>
        <%= new Date(order.createdAt).toLocaleString('en-US', { weekday: 'short' , month: 'short' , day: '2-digit' ,
          year: 'numeric' , }) %>
      </p>
    </div>

    <div class="section">
      <h2>Billing Information</h2>
      <p><strong>Customer Name:</strong>
        <%=order.UserID.firstName%>
      </p>
      <p><strong>Email:</strong>
        <%=order.UserID.email%>
      </p>
      <p><strong>Phone:</strong>
        <%=order.UserID.phone%>
      </p>
      <p><strong>Address:</strong>
        <%=order.addressId.District %>, <%=order.addressId.State %> <br>
            <%=order.addressId.PIN %>, <%=order.addressId.place %>, <%=order.addressId.mark %>
      </p>
    </div>
    <% let hasRefund=order.Products.some(item=> item.refundAmound > 0);
      %>
      <div class="section">
        <h2>Order Summary</h2>
        <table>
          <thead>
            <tr>
              <th>Item Name</th>
              <th>Quantity</th>
              <th>Unit Price</th>
              <th>Status</th>
              <% if (hasRefund) { %>
                <th>Refund Amount</th>
                <% } %>
                  <th>Total</th>
            </tr>
          </thead>
          <tbody>
            <% order.Products.forEach((item)=>{%>


              <tr>
                <td>
                  <%=item.product.productTitle%>
                </td>
                <td>
                  <%=item.quantity%>
                </td>
                <td>₹<%=item.Price%>
                </td>
                <td>
                  <%=item.status%>
                </td>
                <% if (hasRefund) { %>
                  <td>
                    <%= item.refundAmound || '-' %>
                  </td>
                  <% } %>
                    <td>₹<%=item.TOTAL%>
                    </td>
              </tr>
              <%})%>

          </tbody>
          <tfoot>
            <tr>
              <td colspan="4" class="totals">Subtotal</td>
              <td>₹<%=order.subTotal%>
              </td>
            </tr>
            <tr>
              <td colspan="4" class="totals">Discount Value</td>
              <td>₹<%=order.Coupon.discountValue%>
              </td>
            </tr>
            <tr>
              <td colspan="4" class="totals">Shipping Fee</td>
              <td>₹<%=order.Shipping%>
              </td>
            </tr>
            <tr>
              <td colspan="4" class="totals">Total Amount</td>
              <td>₹<%=order.Final_Amount%>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>

      <div class="section">
        <h2>Payment Details</h2>
        <p><strong>Payment Method:</strong>
          <%=order.payment%>
        </p>
        <%if(order.payment=='razorpay'){%>
          <p><strong>Transaction ID:</strong>
            <%=order.RazorPay.razorpay_payment_id%>
          </p>
          <%}%>
      </div>

      <div class="footer">
        <p>For any questions, contact us at support@fruitkha.com </p>
        <p>Thank you for shopping with us! 🍇</p>
      </div>
  </div>
</body>

</html>
