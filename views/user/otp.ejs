<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification — Fruitkha</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/toast.css">
    <link rel="stylesheet" href="/css/pages/otp.css">
</head>

<body>
    <div class="toast-container" id="toastContainer"></div>

    <div class="otp-wrapper">
        <!-- Brand -->
        <div class="otp-brand">
            <a href="/"><img src="/img/logo.png" alt="Fruitkha"></a>
        </div>

        <div class="otp-card">
            <div class="otp-icon">
                <i class="fas fa-shield-alt"></i>
            </div>
            <h1 class="otp-title">Verify Your Email</h1>
            <p class="otp-sub">We've sent a 6-digit verification code to</p>
            <% if (typeof email !=='undefined' ) { %>
                <p class="otp-email">
                    <%= email %>
                </p>
                <% } %>

                    <form id="otpForm">
                        <!-- OTP Input Boxes -->
                        <div class="otp-boxes">
                            <input type="text" maxlength="1" class="otp-input" autofocus>
                            <input type="text" maxlength="1" class="otp-input">
                            <input type="text" maxlength="1" class="otp-input">
                            <input type="text" maxlength="1" class="otp-input">
                            <input type="text" maxlength="1" class="otp-input">
                            <input type="text" maxlength="1" class="otp-input">
                        </div>

                        <!-- Timer -->
                        <div class="timer-row">
                            <div class="timer-display pulse" id="timer">01:00</div>
                            <div class="timer-label">Code expires in</div>
                        </div>

                        <input type="hidden" id="Email-Otp" value="<%= email %>">

                        <button type="submit" class="btn-verify">
                            <i class="fas fa-check-circle"></i> Verify Code
                        </button>
                    </form>

                    <div class="resend-row">
                        Didn't receive it? &nbsp;
                        <button id="resendBtn" disabled>Resend Code</button>
                    </div>

                    <div class="support-link">
                        Need help? <a href="#">Contact Support</a>
                    </div>
        </div>
    </div>

    <script src="/showNotification.js"></script>
    <script>
        // Timer
        function startTimer(duration) {
            let timer = duration;
            const display = document.getElementById('timer');
            const resendBtn = document.getElementById('resendBtn');
            display.classList.add('pulse');
            const interval = setInterval(() => {
                const m = Math.floor(timer / 60);
                const s = timer % 60;
                display.textContent = `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
                if (--timer < 0) {
                    clearInterval(interval);
                    resendBtn.disabled = false;
                    display.textContent = '00:00';
                    display.classList.remove('pulse');
                    display.style.color = '#adb5bd';
                }
            }, 1000);
        }
        startTimer(60);

        // OTP box auto-advance
        const inputs = document.querySelectorAll('.otp-input');
        inputs.forEach((input, index) => {
            input.addEventListener('input', () => {
                if (input.value) {
                    input.classList.add('filled');
                    if (index < inputs.length - 1) inputs[index + 1].focus();
                }
            });
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace') {
                    input.classList.remove('filled');
                    if (!input.value && index > 0) inputs[index - 1].focus();
                }
            });
        });

        // Resend
        document.getElementById('resendBtn').addEventListener('click', () => {
            document.getElementById('resendBtn').disabled = true;
            document.getElementById('timer').style.color = '#F28123';
            startTimer(60);
            inputs.forEach(i => { i.value = ''; i.classList.remove('filled'); });
            inputs[0].focus();
        });
    </script>
    <script src="/js/OTP.js"></script>
</body>

</html>