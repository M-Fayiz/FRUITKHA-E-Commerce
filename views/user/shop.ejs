<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Fruitkha shop — fresh fruits & dairy">
  <title>Shop | Fruitkha</title>

  <link rel="shortcut icon" type="image/png" href="/img/favicon.png">
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@400;500;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/all.min.css">
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/owl.carousel.css">
  <link rel="stylesheet" href="/css/animate.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/pages/shop.css">
  <link rel="stylesheet" href="/toast.css">
</head>

<body>
  <div class="loader">
    <div class="loader-inner">
      <div class="circle"></div>
    </div>
  </div>

  <%- include('../partials/Header.ejs') %>

    <div class="toast-container" id="toastContainer"></div>

    <!-- Filter overlay -->
    <div class="overlay" id="overlay"></div>

    <!-- Filter Panel (slides from right) -->
    <aside class="filter-panel" id="filterPanel" aria-label="Filters panel">
      <div class="filter-head">
        <h3><i class="fas fa-sliders-h"></i> Filters</h3>
        <button class="close-filter-btn" id="closeFilterBtn" aria-label="Close filters">&times;</button>
      </div>
      <div class="filter-body">

        <div class="filter-section">
          <p class="filter-title">Categories</p>
          <div class="cat-pills">
            <% data.forEach(function(item) { %>
              <div class="cat-pill">
                <input class="category-check" type="checkbox" id="cat-<%= item._id %>" value="<%= item._id %>">
                <label for="cat-<%= item._id %>">
                  <i class="fas fa-tag" style="font-size:10px;opacity:.6"></i>
                  <%= item.category %>
                </label>
              </div>
              <% }) %>
          </div>
        </div>

        <div class="filter-section">
          <p class="filter-title">Max Price</p>
          <div class="price-slider-wrap">
            <div class="price-slider-labels">
              <span>&#8377;0</span>
              <span class="now" id="priceValue">&#8377;1000</span>
              <span>&#8377;1000</span>
            </div>
            <input type="range" class="fancy-range" min="0" max="1000" value="1000" id="priceRange">
          </div>
        </div>

        <div class="filter-section">
          <p class="filter-title">Sort By</p>
          <select class="sort-select" id="sortBy">
            <option value="">Default</option>
            <option value="LOW">Price: Low to High</option>
            <option value="HIGH">Price: High to Low</option>
            <option value="NEWEST">Newest Arrivals</option>
            <option value="A_TO_Z">A to Z</option>
            <option value="Z_TO_A">Z to A</option>
          </select>
        </div>

        <div style="display:flex;flex-direction:column;gap:10px;margin-top:auto;">
          <button id="applyFiltersBtn" class="apply-btn"><i class="fas fa-check"></i> Apply Filters</button>
          <button class="reset-btn" onclick="window.location.href='/shop'"><i class="fas fa-redo-alt"></i> Reset
            All</button>
        </div>
      </div>
    </aside>

    <!-- Shop Content -->
    <section class="shop-shell">
      <div class="container">

        <div class="shop-head">
          <div class="shop-head-top">
            <div>
              <h1>Fresh Picks For You</h1>
              <p>Quality fruits &amp; dairy — clean pricing, fast delivery.</p>
            </div>
          </div>
          <div class="toolbar">
            <div class="search-wrap">
              <input type="text" id="search-input" placeholder="Search products by name…" autocomplete="off">
              <i class="fas fa-search"></i>
            </div>
            <button class="search-submit-btn" id="searchSubmitBtn">
              <i class="fas fa-search"></i> Search
            </button>
            <button class="filter-open-btn" id="filterToggleBtn">
              <i class="fas fa-sliders-h"></i> Filters
            </button>
          </div>

          <div class="quick-cats">
            <a class="<%= !Category ? 'active' : '' %>" href="/shop">All</a>
            <% listedCategory.forEach(function(item) { %>
              <a class="<%= Category && Category._id && String(Category._id) === String(item._id) ? 'active' : '' %>"
                href="/shop?category=<%= item._id %>">
                <%= item.category %>
              </a>
              <% }) %>
          </div>
        </div>

        <p class="list-note" id="shopMessage">
          <%= message || '' %>
        </p>

        <div class="products-grid" id="productsContainer">
          <% if (products && products.length> 0) { %>
            <% products.forEach(function(item) { %>
              <article class="product-card" onclick="goToProduct('/product/<%= item._id %>', event)" role="link"
                tabindex="0" aria-label="View <%= item.productTitle %>">

                <div class="product-thumb">
                  <% if (item.Offer && item.Offer.OfferPrice> 0 && item.RegulerPrice > 0) { %>
                    <% const offer=Math.round(((item.RegulerPrice - item.Offer.OfferPrice) / item.RegulerPrice) * 100);
                      %>
                      <% if (offer> 0) { %>
                        <span class="offer-tag">
                          <%= offer %>% OFF
                        </span>
                        <% } %>
                          <% } %>

                            <button class="wishlist-btn <%= item.isInWishlist ? 'is-active' : '' %>"
                              id="wishlistIcon-<%= item._id %>" onclick="wishList('<%= item._id %>', event)"
                              aria-label="Toggle wishlist">
                              <i class="<%= item.isInWishlist ? 'fas fa-heart' : 'far fa-heart' %>"></i>
                            </button>

                            <img src="/images/<%= item.primaryImage %>" alt="<%= item.productTitle %>" loading="lazy">
                </div>

                <div class="product-content">
                  <div class="price-block">
                    <% if (item.Offer && item.Offer.OfferPrice> 0) { %>
                      <span class="price-now">&#8377;<%= item.Offer.OfferPrice %></span>
                      <span class="price-old">&#8377;<%= item.RegulerPrice %></span>
                      <% } else { %>
                        <span class="price-now">&#8377;<%= item.RegulerPrice %></span>
                        <% } %>
                  </div>

                  <h3 class="product-title">
                    <%= item.productTitle %>
                  </h3>

                  <% if (item.totalStock> 10) { %>
                    <span class="stock-pill stock-in">In Stock · <%= item.totalStock %> kg</span>
                    <% } else if (item.totalStock> 0) { %>
                      <span class="stock-pill stock-low">Low Stock · <%= item.totalStock %> kg</span>
                      <% } else { %>
                        <span class="stock-pill stock-out">Out of Stock</span>
                        <% } %>

                          <button class="cart-btn" onclick="addToCart('<%= item._id %>', event)" <%=item.totalStock> 0 ?
                            '' : 'disabled' %>>
                            <i class="fas fa-shopping-cart"></i>
                            <%= item.totalStock> 0 ? 'Add to Cart' : 'Unavailable' %>
                          </button>
                </div>

              </article>
              <% }) %>
                <% } else { %>
                  <div class="empty-state" style="grid-column:1/-1">
                    <i class="fas fa-box-open"></i>
                    <h3>No products found</h3>
                    <p>Try adjusting your search or filters</p>
                  </div>
                  <% } %>
        </div>

        <% if (totalPages> 1) { %>
          <div class="pagination-wrap">
            <ul>
              <% if (currentPage> 1) { %>
                <li><a href="/shop?page=<%= currentPage - 1 %>">&#8592; Prev</a></li>
                <% } %>
                  <% for (let i=1; i <=totalPages; i++) { %>
                    <li><a class="<%= i === currentPage ? 'active' : '' %>" href="/shop?page=<%= i %>">
                        <%= i %>
                      </a></li>
                    <% } %>
                      <% if (currentPage < totalPages) { %>
                        <li><a href="/shop?page=<%= currentPage + 1 %>">Next &#8594;</a></li>
                        <% } %>
            </ul>
          </div>
          <% } %>

      </div>
    </section>

    <script src="/showNotification.js"></script>
    <script src="/js/shop.js"></script>
    <script src="/js/jquery-1.11.3.min.js"></script>
    <script src="/bootstrap/js/bootstrap.min.js"></script>
    <script src="/js/owl.carousel.min.js"></script>
    <script src="/js/main.js"></script>

    <script>
      /* Hide loader */
      window.addEventListener('load', () => {
        const l = document.querySelector('.loader');
        if (l) { l.style.opacity = '0'; setTimeout(() => l.remove(), 400); }
      });

      /* Price range slider gradient */
      const pr = document.getElementById('priceRange');
      if (pr) {
        function updateSlider() {
          const pct = (pr.value / pr.max) * 100;
          pr.style.background = `linear-gradient(to right, #f97316 0%, #f97316 ${pct}%, #e2e8f0 ${pct}%, #e2e8f0 100%)`;
          document.getElementById('priceValue').textContent = '₹' + pr.value;
        }
        pr.addEventListener('input', updateSlider);
        updateSlider();
      }

      /* Filter panel toggle */
      const filterToggleBtn = document.getElementById('filterToggleBtn');
      const filterPanel = document.getElementById('filterPanel');
      const overlay = document.getElementById('overlay');
      const closeFilterBtn = document.getElementById('closeFilterBtn');

      function openFilter() {
        filterPanel.classList.add('open');
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeFilter() {
        filterPanel.classList.remove('open');
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }

      if (filterToggleBtn) filterToggleBtn.addEventListener('click', openFilter);
      if (closeFilterBtn) closeFilterBtn.addEventListener('click', closeFilter);
      if (overlay) overlay.addEventListener('click', closeFilter);


      document.querySelectorAll('.product-card').forEach(card => {
        card.addEventListener('keydown', e => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            if (!e.target.closest('button')) {
              const href = card.getAttribute('onclick');
              const match = href && href.match(/goToProduct\('([^']+)'/);
              if (match) window.location.href = match[1];
            }
          }
        });
      });
    </script>
</body>

</html>
