<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Details — Fruitkha</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link rel="stylesheet" href="/SHOW.css">
  <link rel="stylesheet" href="/user-theme.css">
  <link rel="stylesheet" href="/css/pages/order-details.css">

</head>

<body>

  <!-- Top bar with back button -->
  <header class="od-topbar">
    <a href="/"><img src="/img/logo.png" alt="Fruitkha"></a>
    <a href="/orderList" class="back-btn">
      <i class="fas fa-arrow-left"></i> Back to Orders
    </a>
  </header>

  <%- include('../partials/block.ejs') %>

    <div class="od-page">

      <!-- Order Status Tracking -->
      <% const statuses=['Pending','Shipped','On Delivery','Delivered']; const
        currentIdx=statuses.indexOf(Order.orderStatus); %>
        <% if (Order.orderStatus !=='Cancelled' && Order.orderStatus !=='Returned' ) { %>
          <div class="section-card">
            <div class="section-card-title"><i class="fas fa-route"></i> Order Tracking</div>
            <div class="tracking-bar">
              <% const icons=['fas fa-box','fas fa-truck','fas fa-shipping-fast','fas fa-check-circle']; %>
                <% statuses.forEach((st, idx)=> { %>
                  <div class="track-step">
                    <div class="track-icon <%= idx < currentIdx ? 'done' : (idx === currentIdx ? 'current' : '') %>">
                      <i class="<%= icons[idx] %>"></i>
                    </div>
                    <span class="track-label">
                      <%= st %>
                    </span>
                  </div>
                  <% }) %>
            </div>
          </div>
          <% } %>

            <!-- Order Info -->
            <div class="section-card">
              <div class="section-card-title"><i class="fas fa-info-circle"></i> Order Information</div>
              <div class="od-info-grid">
                <div class="od-info-item">
                  <div class="label">Order ID</div>
                  <div class="value" style="font-family:monospace;font-size:12.5px;">
                    <%= Order._id %>
                  </div>
                </div>
                <div class="od-info-item">
                  <div class="label">Order Date</div>
                  <div class="value">
                    <%= new
                      Date(Order.createdAt).toLocaleString('en-IN',{weekday:'short',month:'short',day:'2-digit',year:'numeric',hour:'numeric',minute:'2-digit',hour12:true})
                      %>
                  </div>
                </div>
                <% if (Order.orderStatus !=='Cancelled' ) { %>
                  <div class="od-info-item">
                    <div class="label">Expected Delivery</div>
                    <div class="value">
                      <%= new Date(new
                        Date(Order.createdAt).getTime()+24*60*60*1000).toLocaleString('en-IN',{weekday:'short',month:'short',day:'2-digit',year:'numeric'})
                        %>
                    </div>
                  </div>
                  <% } %>
                    <div class="od-info-item">
                      <div class="label">Order Status</div>
                      <div class="value">
                        <span class="status-pill <%=
              Order.orderStatus==='Pending'?'s-pending':
              Order.orderStatus==='Shipped'?'s-shipped':
              Order.orderStatus==='On Delivery'?'s-ondelivery':
              Order.orderStatus==='Delivered'?'s-delivered':
              Order.orderStatus==='Cancelled'?'s-cancelled':
              Order.orderStatus==='Returned'?'s-return':''
            %>">
                          <%= Order.orderStatus %>
                        </span>
                      </div>
                    </div>
              </div>
              <!-- Action buttons -->
              <div class="d-flex gap-3 flex-wrap mt-4">
                <% if(Order.payment==='razorpay' && Order.paymentStatus==='Pending' && Order.orderStatus!=='Cancelled'
                  ){ %>
                  <button class="btn-orange" id="orderID" data-id="<%= Order._id %>">
                    <i class="fas fa-credit-card me-1"></i> Retry Payment
                  </button>
                  <% } %>
                    <% if(Order.paymentStatus==='Completed' ){ %>
                      <button onclick="download('<%= Order.id %>')" class="btn-outline-orange"
                        style="border-radius:8px;">
                        <i class="fas fa-file-invoice me-1"></i> Download Invoice
                      </button>
                      <% } %>
              </div>
            </div>

            <!-- Products Table -->
            <div class="section-card">
              <div class="section-card-title"><i class="fas fa-boxes"></i> Products</div>
              <div class="table-responsive">
                <table class="prod-table">
                  <thead>
                    <tr>
                      <th colspan="2">Product</th>
                      <th>Qty</th>
                      <th>Price</th>
                      <th>Subtotal</th>
                      <th>Status</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% Order.Products.forEach(item=>{ %>
                      <tr>
                        <td><img src="<%= item.product.primaryImage %>" class="prod-img" alt="" style="width:60px;height:60px;object-fit:cover;border-radius:6px;"></td>
                        <td>
                          <div class="prod-title">
                            <%= item.product.productTitle %>
                          </div>
                          <div class="prod-desc">
                            <%= item.product.description ? item.product.description.substring(0,50) : '' %>
                          </div>
                        </td>
                        <td>
                          <%= item.quantity %> kg
                        </td>
                        <td>
                          <span style="font-weight:600;color:#1a7a3a;">₹<%= item.Price %></span>
                          <% if (item.Price < item.product.RegulerPrice) { %>
                            <div><del style="color:#aaa;font-size:12px;">₹<%= item.product.RegulerPrice %></del></div>
                          <% } %>
                        </td>
                        <td style="font-weight:600;">₹<%= item.TOTAL %>
                        </td>
                        <td>
                          <span class="status-pill <%=
                  item.status==='Pending'?'s-pending':
                  item.status==='Shipped'?'s-shipped':
                  item.status==='On Delivery'?'s-ondelivery':
                  item.status==='Delivered'?'s-delivered':
                  item.status==='Cancelled'?'s-cancelled':
                  item.status==='Returned'?'s-return':''
                %>">
                            <%= item.status %>
                          </span>
                        </td>
                        <td>
                          <% if(item.status==='Delivered' && item.return.req===false && Order.orderStatus!=='Returned'
                            ){ %>
                            <button class="btn btn-sm btn-outline-secondary" style="border-radius:8px;font-size:12px;"
                              data-order-id="<%= Order._id %>" data-product="<%= item.product.id %>"
                              onclick="returnItem(this)">
                              <i class="fas fa-undo me-1"></i>Return
                            </button>
                            <% } else if(item.status!=='Cancelled' && item.return.req===false &&
                              item.status!=='Delivered' && item.status!=='Returned' ){ %>
                              <button class="btn btn-sm btn-outline-danger" style="border-radius:8px;font-size:12px;"
                                data-id="<%= item.id %>" data-order-id="<%= Order._id %>"
                                data-product="<%= item.product.id %>" data-quantity="<%= item.quantity %>"
                                onclick="cancelFromButton(this)">
                                <i class="fas fa-times me-1"></i>Cancel
                              </button>
                              <% } else if(item.return.req===true && item.status!=='Returned' ){ %>
                                <span style="color:#e65100;font-size:12px;"><i class="fas fa-clock me-1"></i>Return
                                  Requested</span>
                                <% } %>
                        </td>
                      </tr>
                      <% }) %>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Address + Pricing + Payment row -->
            <div class="row g-4">
              <div class="col-md-5">
                <div class="section-card h-100">
                  <div class="section-card-title"><i class="fas fa-map-marker-alt"></i> Delivery Address</div>
                  <div style="font-size:14px;line-height:1.8;">
                    <p style="margin:0;font-weight:600;">
                      <%= Order.addressId.Name %>
                    </p>
                    <p style="margin:0;color:var(--fr-muted)">
                      <%= Order.addressId.place %>, <%= Order.addressId.District %>
                    </p>
                    <p style="margin:0;color:var(--fr-muted)">
                      <%= Order.addressId.State %> — <%= Order.addressId.PIN %>
                    </p>
                    <p style="margin:0;color:var(--fr-muted)">Landmark: <%= Order.addressId.mark %>
                    </p>
                    <p style="margin:0;margin-top:6px;"><i class="fas fa-phone me-1"
                        style="color:var(--fr-orange)"></i>+91 <%= Order.UserID.phone %>
                    </p>
                  </div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="section-card h-100">
                  <div class="section-card-title"><i class="fas fa-receipt"></i> Price Summary</div>
                  <div class="price-row"><span class="label">Subtotal</span><span>₹<%= (Order.subTotal).toFixed(2) %>
                    </span></div>
                  <div class="price-row"><span class="label">GST</span><span>₹<%= (Order.GST).toFixed(2) %></span></div>
                  <div class="price-row"><span class="label">Discount</span><span style="color:#1a7a3a;">−₹<%=
                        (Order.Coupon.discountValue).toFixed(2) %></span></div>
                  <div class="price-row"><span class="label">Shipping</span><span>₹<%= (Order.Shipping).toFixed(2) %>
                    </span></div>
                  <div class="price-row total"><span>Total</span><span style="color:var(--fr-orange)">₹<%=
                        (Order.Final_Amount).toFixed(2) %></span></div>
                </div>
              </div>
              <div class="col-md-3">
                <div class="section-card h-100">
                  <div class="section-card-title"><i class="fas fa-credit-card"></i> Payment</div>
                  <div style="font-size:14px;">
                    <% if(Order.payment==='COD' ){ %>
                      <div style="font-weight:600;"><i class="fas fa-money-bill me-2"
                          style="color:var(--fr-orange)"></i>Cash on Delivery</div>
                      <% } else if(Order.payment==='razorpay' ){ %>
                        <div style="font-weight:600;"><i class="fas fa-bolt me-2"
                            style="color:var(--fr-orange)"></i>Razorpay</div>
                        <div style="color:var(--fr-muted);font-size:13px;margin-top:4px;">
                          <%= Order.paymentStatus %>
                        </div>
                        <% } else if(Order.payment==='wallet' ){ %>
                          <div style="font-weight:600;"><i class="fas fa-wallet me-2"
                              style="color:var(--fr-orange)"></i>Wallet</div>
                          <div style="color:var(--fr-muted);font-size:13px;margin-top:4px;">
                            <%= Order.paymentStatus %>
                          </div>
                          <% } %>
                  </div>
                </div>
              </div>
            </div>

    </div><!-- /od-page -->

    <!-- Return Modal -->
    <div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:var(--fr-radius);border:none;">
          <form id="return-form" enctype="multipart/form-data">
            <div class="modal-header"
              style="background:var(--fr-orange-light);border-bottom:1px solid var(--fr-border);">
              <h5 class="modal-title" style="color:var(--fr-orange);font-weight:700;"><i
                  class="fas fa-undo me-2"></i>Return Request</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3 p-3" style="background:#f8f9fb;border-radius:8px;">
                <p style="font-size:13px;color:var(--fr-muted);margin:0;">Returns accepted for: damaged or expired
                  products. Upload proof and provide reason.</p>
              </div>
              <div class="mb-3">
                <label class="form-label">Upload Product Image</label>
                <input type="file" id="productImage" class="form-control" accept="image/png,image/jpeg,image/jpg"
                  required>
              </div>
              <div class="mb-3">
                <label class="form-label">Reason for Return</label>
                <textarea id="returnReason" class="form-control" rows="3" placeholder="Describe the issue..."
                  required></textarea>
              </div>
              <input type="hidden" id="OrderId">
              <input type="hidden" id="productId">
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"
                style="border-radius:8px;">Cancel</button>
              <button type="submit" class="btn-orange" id="submitReturn" style="border:none;">Submit Request</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script src="/TOAST.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="/js/userOrderDetails.js"></script>
</body>

</html>