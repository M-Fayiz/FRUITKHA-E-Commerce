<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Wallet — Fruitkha</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/user-theme.css">
  <link rel="stylesheet" href="/SHOW.css">
  <% const currentPath='wallet' ; %>
    <link rel="stylesheet" href="/css/pages/wallet.css">
</head>

<body>
  <!-- Top Bar -->
  <header class="profile-topbar">
    <a href="/"><img src="/img/logo.png" alt="Fruitkha" class="brand-logo"></a>
    <button class="topbar-toggle d-md-none" id="sidebarToggleBtn"><i class="fas fa-bars"></i></button>
  </header>

  <div class="profile-layout">
    <%- include('../partials/profileSIDEBAR.ejs') %>

      <main class="page-content">

        <!-- Balance Card -->
        <div class="wallet-balance-card">
          <div>
            <div class="balance-label">Available Balance</div>
            <p class="balance-amount">
              ₹ <% if (Wallet && Wallet.balance !==null) { %>
                <%= Wallet.balance.toFixed(2) %>
                  <% } else { %>0.00<% } %>
            </p>
          </div>
          <div class="wallet-icon-wrap">
            <i class="fas fa-wallet"></i>
          </div>
        </div>

        <!-- Transaction History -->
        <div class="content-card">
          <div class="page-header">
            <div class="page-header-icon"><i class="fas fa-history"></i></div>
            <div>
              <h5 class="ph-title">Transaction History</h5>
              <span class="ph-sub">All your wallet credits and debits</span>
            </div>
          </div>

          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead style="background:#f8f9fb;">
                <tr>
                  <th style="font-size:13px;font-weight:600;color:var(--fr-muted);padding:12px 16px;">Date</th>
                  <th style="font-size:13px;font-weight:600;color:var(--fr-muted);padding:12px 16px;">Type</th>
                  <th style="font-size:13px;font-weight:600;color:var(--fr-muted);padding:12px 16px;">Amount</th>
                </tr>
              </thead>
              <tbody>
                <% if (Wallet && Wallet.transactions && Wallet.transactions.length> 0) { %>
                  <% Wallet.transactions.sort((a,b)=>b.date-a.date) %>
                    <% Wallet.transactions.forEach(item=>{ %>
                      <tr class="txn-row">
                        <td><i class="far fa-calendar-alt me-2" style="color:var(--fr-muted)"></i>
                          <%= new Date(item.date).toLocaleDateString('en-IN',
                            {day:'2-digit',month:'short',year:'numeric'}) %>
                        </td>
                        <td>
                          <span class="txn-badge <%= item.type==='credit' ? 'txn-credit' : 'txn-debit' %>">
                            <i class="fas fa-<%= item.type==='credit' ? 'arrow-down' : 'arrow-up' %> me-1"></i>
                            <%= item.type %>
                          </span>
                        </td>
                        <td style="font-weight:600; color:<%= item.type==='credit'?'#1a7a3a':'#c0392b' %>">
                          <%= item.type==='credit' ? '+' : '-' %>₹<%= item.amount %>
                        </td>
                      </tr>
                      <% }) %>
                        <% } else { %>
                          <tr>
                            <td colspan="3" class="text-center py-5">
                              <i class="fas fa-receipt fa-3x mb-3" style="color:var(--fr-border)"></i>
                              <p class="mb-0" style="color:var(--fr-muted)">No transactions yet</p>
                            </td>
                          </tr>
                          <% } %>
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <div class="d-flex justify-content-center gap-2 mt-4">
            <% if (currentPage> 1) { %>
              <a href="/wallet?page=<%= currentPage - 1 %>" class="pagination-btn">
                <i class="fas fa-chevron-left me-1"></i> Prev
              </a>
              <% } %>
                <% const maxButtons=3; let startPage=Math.max(1,currentPage-Math.floor(maxButtons/2)); let
                  endPage=Math.min(totalPages,startPage+maxButtons-1);
                  if(endPage-startPage+1<maxButtons){startPage=Math.max(1,endPage-maxButtons+1);} %>
                  <% for(let i=startPage;i<=endPage;i++){%>
                    <a href="/wallet?page=<%= i %>" class="pagination-btn <%= i===currentPage?'active':'' %>">
                      <%= i %>
                    </a>
                    <%}%>
                      <% if (currentPage < totalPages) { %>
                        <a href="/wallet?page=<%= currentPage + 1 %>" class="pagination-btn">
                          Next <i class="fas fa-chevron-right ms-1"></i>
                        </a>
                        <% } %>
          </div>
        </div>

      </main>
  </div>

  <%- include('../partials/block.ejs') %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script>
      const sidebarToggleBtn = document.getElementById('sidebarToggleBtn');
      const userSidebar = document.getElementById('userSidebar');
      if (sidebarToggleBtn && userSidebar) {
        sidebarToggleBtn.addEventListener('click', () => userSidebar.classList.toggle('collapsed'));
      }
    </script>
</body>

</html>