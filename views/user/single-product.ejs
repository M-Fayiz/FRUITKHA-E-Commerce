<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>
		<%= item.productTitle %> | Fruitkha
	</title>
	<meta name="description" content="<%= item.description %>">

	<link rel="shortcut icon" type="image/png" href="/img/favicon.png">
	<link
		href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@400;500;600;700&display=swap"
		rel="stylesheet">
	<link rel="stylesheet" href="/css/all.min.css">
	<link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
	<link rel="stylesheet" href="/css/owl.carousel.css">
	<link rel="stylesheet" href="/css/animate.css">
	<link rel="stylesheet" href="/css/main.css">
	<link rel="stylesheet" href="/css/responsive.css">
	<link rel="stylesheet" href="/toast.css">
	<link rel="stylesheet" href="/css/pages/single-product.css">
	<%- include('../partials/toast.ejs') %>
</head>

<body>

	<div class="loader">
		<div class="loader-inner">
			<div class="circle"></div>
		</div>
	</div>

	<%- include('../partials/Header.ejs') %>
		<div class="toast-container" id="toastContainer"></div>

		<div class="breadcrumb-section breadcrumb-bg">
			<div class="container">
				<div class="col-lg-8 offset-lg-2 text-center">
					<div class="breadcrumb-text">
						<div class="pd-breadcrumb justify-content-center">
							<a href="/"><i class="fas fa-home"></i> Home</a>
							<span class="sep">›</span>
							<a href="/shop">Shop</a>
							<span class="sep">›</span>
							<span class="current">
								<%= item.productTitle %>
							</span>
						</div>
						<h1 style="margin-top:6px">
							<%= item.productTitle %>
						</h1>
					</div>
				</div>
			</div>
		</div>

		<!-- ── Product main section ── -->
		<section class="pd-section">
			<div class="container">
				<div class="pd-grid">

					<!-- Gallery -->
					<div class="pd-gallery">
						<div class="pd-main-img" id="mainImgContainer">
							<% if (item.Offer && item.Offer.OfferPrice> 0 && item.RegulerPrice > 0) { %>
								<% const offerPct=Math.round(((item.RegulerPrice - item.Offer.OfferPrice) /
									item.RegulerPrice) * 100); %>
									<% if (offerPct> 0) { %>
										<span class="offer-badge-lg">
											<%= offerPct %>% OFF
										</span>
										<% } %>
											<% } %>
												<img id="mainImage" src="/images/<%= item.primaryImage %>"
													alt="<%= item.productTitle %>">
						</div>
						<div class="pd-thumbs">
							<div class="pd-thumb active"
								onclick="changeThumb(this, '/images/<%= item.primaryImage %>')">
								<img src="/images/<%= item.primaryImage %>" alt="Thumbnail 1">
							</div>
							<% if (item.additonalImage && item.additonalImage[0]) { %>
								<div class="pd-thumb"
									onclick="changeThumb(this, '/images/<%= item.additonalImage[0] %>')">
									<img src="/images/<%= item.additonalImage[0] %>" alt="Thumbnail 2">
								</div>
								<% } %>
									<% if (item.additonalImage && item.additonalImage[1]) { %>
										<div class="pd-thumb"
											onclick="changeThumb(this, '/images/<%= item.additonalImage[1] %>')">
											<img src="/images/<%= item.additonalImage[1] %>" alt="Thumbnail 3">
										</div>
										<% } %>
						</div>
					</div>

					<!-- Info panel -->
					<div class="pd-info">

						<div class="pd-cat-badge">
							<i class="fas fa-tag" style="font-size:10px"></i>
							<%= item.Category ? (cat ? cat.category : item.Category) : 'Product' %>
						</div>

						<h1 class="pd-title">
							<%= item.productTitle %>
						</h1>
						<p class="pd-description">
							<%= item.description %>
						</p>

						<div class="pd-rating">
							<span class="rating-val">4.5</span>
							<span class="stars">★★★★½</span>
							<span class="rating-count">(10 reviews)</span>
						</div>

						<div class="pd-price-block">
							<div>
								<div class="price-unit">Per Kilogram</div>
								<% if (item.Offer && item.Offer.OfferPrice> 0) { %>
									<div class="price-main offer">₹<%= item.Offer.OfferPrice %>
									</div>
									<% } else { %>
										<div class="price-main">₹<%= item.RegulerPrice %>
										</div>
										<% } %>
							</div>
							<% if (item.Offer && item.Offer.OfferPrice> 0) { %>
								<div>
									<span class="price-slash">₹<%= item.RegulerPrice %></span>
								</div>
								<% const savePct=Math.round(((item.RegulerPrice - item.Offer.OfferPrice) /
									item.RegulerPrice) * 100); %>
									<span class="save-badge">Save <%= savePct %>%</span>
									<% } %>
						</div>

						<div class="pd-stock-row">
							<% if (item.totalStock> 10) { %>
								<span class="stock-dot in"></span>
								<span class="stock-label in">In Stock — <%= item.totalStock %> kg available</span>
								<% } else if (item.totalStock> 0) { %>
									<span class="stock-dot low"></span>
									<span class="stock-label low">Low Stock — only <%= item.totalStock %> kg left</span>
									<% } else { %>
										<span class="stock-dot out"></span>
										<span class="stock-label out">Out of Stock</span>
										<% } %>
						</div>

						<div class="pd-qty-label">Quantity</div>
						<div class="qty-control">
							<button class="qty-btn" onclick="changeQty(-1)">−</button>
							<input type="number" id="num" class="qty-input" value="1" min="1"
								max="<%= item.totalStock %>">
							<button class="qty-btn" onclick="changeQty(1)">+</button>
							<span class="qty-unit">kg</span>
						</div>

						<div class="pd-actions">
							<% if (item.totalStock> 0) { %>
								<button class="btn-cart"
									onclick="pass('<%= item.id %>','<%= item.productTitle %>','<%= item.RegulerPrice %>','<%= item.Offer ? item.Offer.OfferPrice : item.OfferPrice %>')">
									<i class="fas fa-shopping-cart"></i> Add to Cart
								</button>
								<% } else { %>
									<button class="btn-cart disabled" disabled>
										<i class="fas fa-ban"></i> Unavailable
									</button>
									<% } %>
										<button class="btn-wishlist <%= item.isWishList ? 'active' : '' %>"
											id="wishlistIcon1" data-id="<%= item._id %>" title="Add to wishlist">
											<i class="<%= item.isWishList ? 'fas fa-heart' : 'far fa-heart' %>"></i>
										</button>
						</div>

						<div class="pd-meta">
							<div class="pd-meta-row"><i class="fas fa-leaf"></i> <span>Category: <strong>
										<%= cat ? cat.category : item.Category %>
									</strong></span></div>
							<div class="pd-meta-row"><i class="fas fa-truck"></i> <span>Free delivery on orders above
									₹500</span></div>
							<div class="pd-meta-row"><i class="fas fa-undo-alt"></i> <span>Easy returns within 24
									hours</span></div>
							<div class="pd-meta-row"><i class="fas fa-shield-alt"></i> <span>100% fresh quality
									guarantee</span></div>
						</div>
					</div>

				</div>

				<!-- ── Tabs ── -->
				<div class="pd-tabs-section">
					<div class="pd-tabs-nav">
						<button class="pd-tab-btn active" onclick="switchTab('description', this)">Description</button>
						<button class="pd-tab-btn" onclick="switchTab('nutrition', this)">Nutrition Info</button>
						<button class="pd-tab-btn" onclick="switchTab('reviews', this)">Reviews</button>
					</div>

					<div id="tab-description" class="pd-tab-pane active">
						<div class="desc-card">
							<h4>
								<%= item.productTitle %>
							</h4>
							<p>
								<%= item.description %>
							</p>
							<p style="margin-top:14px;color:var(--muted)">
								All our products are sourced directly from verified farms and delivered fresh.
								We maintain strict quality checks to ensure you get the best produce every time.
							</p>
						</div>
					</div>

					<div id="tab-nutrition" class="pd-tab-pane">
						<div class="desc-card">
							<h4>Nutrition Information (per 100g)</h4>
							<table class="nutrition-table">
								<thead>
									<tr>
										<th>Nutrient</th>
										<th>Amount</th>
									</tr>
								</thead>
								<tbody>
									<tr>
										<td>Calories</td>
										<td>52 kcal</td>
									</tr>
									<tr>
										<td>Carbohydrates</td>
										<td>14 g</td>
									</tr>
									<tr>
										<td>Protein</td>
										<td>0.3 g</td>
									</tr>
									<tr>
										<td>Fat</td>
										<td>0.2 g</td>
									</tr>
									<tr>
										<td>Fiber</td>
										<td>2.4 g</td>
									</tr>
									<tr>
										<td>Vitamin C</td>
										<td>4.6 mg</td>
									</tr>
									<tr>
										<td>Potassium</td>
										<td>107 mg</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>

					<div id="tab-reviews" class="pd-tab-pane">
						<div class="review-card">
							<div class="review-header">
								<div class="reviewer-avatar">J</div>
								<div>
									<div class="reviewer-name">John Doe</div>
									<div class="reviewer-date">February 2025</div>
								</div>
								<span class="review-stars ms-auto">★★★★★</span>
							</div>
							<p class="review-text">"Excellent quality! The freshness is unmatched and delivery was super
								fast."</p>
						</div>
						<div class="review-card">
							<div class="review-header">
								<div class="reviewer-avatar">S</div>
								<div>
									<div class="reviewer-name">Sarah K.</div>
									<div class="reviewer-date">January 2025</div>
								</div>
								<span class="review-stars ms-auto">★★★★☆</span>
							</div>
							<p class="review-text">"Good value for money. Packaging could be slightly better but the
								product itself is great."</p>
						</div>
						<div class="review-form-card">
							<h4>Leave a Review</h4>
							<form action="/submit-review" method="POST">
								<div class="form-group">
									<label>Your Name</label>
									<input type="text" name="name" required placeholder="John Doe">
								</div>
								<div class="form-group">
									<label>Rating</label>
									<select name="rating">
										<option value="5">★★★★★ Excellent</option>
										<option value="4">★★★★☆ Very Good</option>
										<option value="3">★★★☆☆ Average</option>
										<option value="2">★★☆☆☆ Poor</option>
										<option value="1">★☆☆☆☆ Very Poor</option>
									</select>
								</div>
								<div class="form-group">
									<label>Your Review</label>
									<textarea name="review" required
										placeholder="Tell us about your experience…"></textarea>
								</div>
								<button type="submit" class="submit-review-btn"><i class="fas fa-paper-plane"></i>
									Submit Review</button>
							</form>
						</div>
					</div>
				</div>

			</div>
		</section>

		<!-- ── Related products ── -->
		<section class="related-section">
			<div class="container">
				<div class="section-heading">
					<div class="label">You Might Also Like</div>
					<h2>Related Products</h2>
				</div>

				<div class="related-grid">
					<% related.forEach(function(rel) { %>
						<% if (rel.isList===true) { %>
							<article class="rel-card" onclick="window.location.href='/product/<%= rel._id %>'"
								role="link" tabindex="0">
								<div class="rel-thumb">
									<% if (rel.OfferPrice> 0 && rel.RegulerPrice > 0) { %>
										<% const relOffer=Math.round(((rel.RegulerPrice - rel.OfferPrice) /
											rel.RegulerPrice) * 100); %>
											<% if (relOffer> 0) { %>
												<span class="rel-offer">
													<%= relOffer %>% OFF
												</span>
												<% } %>
													<% } %>
														<img src="/images/<%= rel.primaryImage %>"
															alt="<%= rel.productTitle %>" loading="lazy">
								</div>
								<div class="rel-body">
									<h3 class="rel-title">
										<%= rel.productTitle %>
									</h3>
									<div class="rel-price-block">
										<% if (rel.OfferPrice> 0) { %>
											<span class="rel-price-now">₹<%= rel.OfferPrice %></span>
											<span class="rel-price-old">₹<%= rel.RegulerPrice %></span>
											<% } else { %>
												<span class="rel-price-now">₹<%= rel.RegulerPrice %></span>
												<% } %>
									</div>
									<% if (rel.totalStock> 10) { %>
										<span class="rel-stock in">In Stock</span>
										<% } else if (rel.totalStock> 0) { %>
											<span class="rel-stock low">Low Stock</span>
											<% } else { %>
												<span class="rel-stock out">Out of Stock</span>
												<% } %>
													<% if (rel.totalStock> 0) { %>
														<button class="rel-cart-btn"
															onclick="event.stopPropagation(); pass('<%= rel.id %>','<%= rel.productTitle %>','<%= rel.RegulerPrice %>','<%= rel.OfferPrice %>')">
															<i class="fas fa-cart-plus"></i> Add to Cart
														</button>
														<% } else { %>
															<button class="rel-cart-btn" disabled
																onclick="event.stopPropagation()">
																<i class="fas fa-ban"></i> Unavailable
															</button>
															<% } %>
								</div>
							</article>
							<% } %>
								<% }) %>
				</div>
			</div>
		</section>

		<%- include('../partials/footer.ejs') %>

			<script src="/showNotification.js"></script>
			<script src="/js/jquery-1.11.3.min.js"></script>
			<script src="/bootstrap/js/bootstrap.min.js"></script>
			<script src="/js/owl.carousel.min.js"></script>
			<script src="/js/main.js"></script>

			<script>
				/* Hide loader */
				window.addEventListener('load', () => {
					const l = document.querySelector('.loader');
					if (l) { l.style.opacity = '0'; setTimeout(() => l.remove(), 400); }
				});

				/* ── Thumbnail switcher ── */
				function changeThumb(el, src) {
					document.getElementById('mainImage').src = src;
					document.querySelectorAll('.pd-thumb').forEach(t => t.classList.remove('active'));
					el.classList.add('active');
				}

				/* ── Zoom on main image ── */
				const mainImgEl = document.getElementById('mainImage');
				const mainContainer = document.getElementById('mainImgContainer');
				if (mainContainer) {
					mainContainer.addEventListener('mousemove', e => {
						const b = mainContainer.getBoundingClientRect();
						const x = ((e.clientX - b.left) / b.width) * 100;
						const y = ((e.clientY - b.top) / b.height) * 100;
						mainImgEl.style.transformOrigin = `${x}% ${y}%`;
						mainImgEl.style.transform = 'scale(1.55)';
					});
					mainContainer.addEventListener('mouseleave', () => {
						mainImgEl.style.transform = 'scale(1)';
					});
				}

				/* ── Quantity control ── */
				function changeQty(delta) {
					const input = document.getElementById('num');
					let val = parseInt(input.value) || 1;
					const max = parseInt(input.max) || 9999;
					val = Math.max(1, Math.min(max, val + delta));
					input.value = val;
				}

				/* ── Tab switcher ── */
				function switchTab(id, btn) {
					document.querySelectorAll('.pd-tab-pane').forEach(p => p.classList.remove('active'));
					document.querySelectorAll('.pd-tab-btn').forEach(b => b.classList.remove('active'));
					document.getElementById('tab-' + id).classList.add('active');
					btn.classList.add('active');
				}

				/* ── Add to cart ── */
				function pass(productId, name, Reguler, Offer) {
					const quantity = document.getElementById('num').value;
					fetch('/api/cart/items', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ productId, name, Reguler, Offer, quantity }),
					})
						.then(r => r.json())
						.then(data => {
							if (data.User === false || data.login === false) { location.href = '/login'; return; }
							if (data.success) {
								showToast(data.message, 'success');
								setTimeout(() => location.href = '/cart', 1200);
							} else {
								showToast(data.message, 'error');
							}
						})
						.catch(() => showToast('Something went wrong.', 'error'));
				}

				/* ── Wishlist toggle ── */
				const wishlistBtn = document.getElementById('wishlistIcon1');
				if (wishlistBtn) {
					wishlistBtn.addEventListener('click', () => {
						const val = wishlistBtn.getAttribute('data-id');
						const isActive = wishlistBtn.classList.contains('active');
						fetch('/api/wishlist/items/toggle', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ val, isInWishlist: isActive }),
						})
							.then(r => r.json())
							.then(data => {
								if (data.success) {
									showToast(data.message, 'success');
									wishlistBtn.classList.toggle('active');
									const icon = wishlistBtn.querySelector('i');
									if (icon) {
										icon.className = wishlistBtn.classList.contains('active') ? 'fas fa-heart' : 'far fa-heart';
									}
								} else {
									showToast(data.message || 'Wishlist error', 'error');
								}
							})
							.catch(() => showToast('Something went wrong!', 'error'));
					});
				}
			</script>
</body>

</html>