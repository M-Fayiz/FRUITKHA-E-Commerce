<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Fruitkha</title>

  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="/toast.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>
<div class="auth-page">

  <!-- ── LEFT PANEL ─────────────────────────────────── -->
  <div class="auth-left">
    <div class="auth-left-inner">
      <img src="/img/logo.png" alt="Fruitkha" class="brand-logo">
      <h1>Fresh & Organic<br>Delivered to You</h1>
      <p>Shop the finest fruits and vegetables sourced straight from the farm. Healthy living starts here.</p>
      <img src="/img/fruits-illustration.png" alt="" class="fruit-illustration"
           onerror="this.style.display='none'">
    </div>
  </div>

  <!-- ── RIGHT PANEL ────────────────────────────────── -->
  <div class="auth-right">
    <div class="auth-card">

      <!-- Logo shown only on mobile -->
      <div class="card-logo">
        <img src="/img/logo.png" alt="Fruitkha">
      </div>

      <h2 class="card-title">Welcome Back 👋</h2>
      <p class="card-subtitle">Sign in to your Fruitkha account</p>

      <form id="login_form" novalidate>

        <!-- Email -->
        <div class="field-group">
          <label class="field-label" for="email">Email Address</label>
          <div class="field-wrap">
            <i class="fa fa-envelope field-icon"></i>
            <input type="email" id="email" name="email"
                   placeholder="you@example.com" autocomplete="email" required>
          </div>
        </div>

        <!-- Password -->
        <div class="field-group">
          <label class="field-label" for="password">Password</label>
          <div class="field-wrap">
            <i class="fa fa-lock field-icon"></i>
            <input type="password" id="password" name="password"
                   placeholder="Enter your password" class="has-toggle"
                   autocomplete="current-password" required>
            <i class="fa fa-eye toggle-password" id="toggleLoginPassword"
               title="Show/hide password"></i>
          </div>
        </div>

        <!-- Forgot -->
        <div class="forgot-link-wrap">
          <a href="/rest">Forgot Password?</a>
        </div>

        <!-- Submit -->
        <button type="submit" class="auth-submit-btn">
          <i class="fa fa-sign-in-alt"></i>
          Sign In
        </button>

        <!-- Divider -->
        <div class="auth-divider">or continue with</div>

        <!-- Google -->
        <a href="/auth/google" class="google-auth-btn">
          <img src="/img/icons8-google-logo-96.png" alt="Google">
          Continue with Google
        </a>

        <!-- Switch -->
        <p class="auth-switch">
          Don't have an account? <a href="/signup">Create one free</a>
        </p>

      </form>
    </div>
  </div>

</div>

<script>
  // Password show/hide
  document.getElementById('toggleLoginPassword').addEventListener('click', function () {
    const input = document.getElementById('password');
    const isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    this.classList.toggle('fa-eye', !isHidden);
    this.classList.toggle('fa-eye-slash', isHidden);
  });
</script>

<script src="/js/login.js"></script>
<script src="/showNotification.js"></script>
</body>
</html>