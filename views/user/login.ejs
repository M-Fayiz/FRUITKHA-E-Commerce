<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fruitkha - Login</title>
    <link rel="stylesheet" href="/css/pages/login.css">
    <link rel="stylesheet" href="/toast.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <%-include('../partials/toast.ejs')%>
        <!-- In your header -->
        <link href="https://cdn.jsdelivr.net/npm/cropperjs@1.5.12/dist/cropper.min.css" rel="stylesheet">
        <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.12/dist/cropper.min.js"></script>

</head>

<body>
    <div>
        <div class="toast-container" id="toastContainer"></div>
        <div class="container">
            <div class="logo-container">
                <img src="/img/logo.png" alt="Fruitkha Logo" width="250">
                <!-- <img src="/images/logo.png"> -->
                <!-- <div class="logo-text">
                <h1>Fruitkha</h1>
                <p>Fresh Fruits Online</p>
            </div> -->
            </div>
        </div>
        <form class="login-form" id="login_form">
            <h2 style="font-weight:500 ;">Log in</h2>

            <div class="form-group">
                <input type="email" name="email" id="email" placeholder="Email" required>
            </div>

            <div class="form-group">
                <input type="password" id="password" name="password" placeholder="Password" required>
            </div>

            <button type="submit" class="login-btn">Log in</button>

            <div class="divider">
                <span>or</span>
            </div>

            <div class="links">
                <a href="/signUp">Create an Account</a>
                <a href="/rest">Forgot Password</a>
            </div>

            <a style="text-decoration: none;" href="/auth/google" class="google-btn">
                <img src="/img/icons8-google-logo-96.png" alt="Google Icon" width="20">
                Sign in with Google
            </a>

            <!-- <% if (locals.error) { %>
                <div class="error-message" style="color: red; text-align: center;">
                    <%= error %>
                </div>
            <% } %> -->
        </form>
    </div>

    <script src="js/login.js"></script>
    <script src="/showNotification.js"></script>

    <script>
        // function handleForgot(e){
        //   const email= document.getElementById('email').value
        //   console.log(email, " ", e)
        //   e.href = `/getOTP/${email}`

        // }
    </script>
</body>

</html>