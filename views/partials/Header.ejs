<% /* currentPath & Category & CURRENTpage passed from controllers */ const _cp=(typeof locals.CURRENTpage
    !=='undefined' ? CURRENTpage : '' ).toLowerCase(); const _cat=typeof locals.Category !=='undefined' ? Category :
    null; %>
    <link rel="stylesheet" href="/css/pages/header.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">

    <nav class="fk-nav">
        <div class="fk-nav-inner">
            <!-- Logo -->
            <a href="/" class="fk-logo"><img src="/img/logo.png" alt="Fruitkha"></a>

            <!-- Main links -->
            <ul class="fk-links">
                <li><a href="/" class="<%= _cp === 'home' ? 'fk-active' : '' %>"><i class="fas fa-home"></i> Home</a>
                </li>
                <li><a href="/shop" class="<%= _cp === 'shop' ? 'fk-active' : '' %>"><i class="fas fa-store"></i>
                        Shop</a></li>
            </ul>

            <!-- Right icons -->
            <div class="fk-icons">
                <!-- Search -->
                <% if (_cp !=='shop' ) { %>
                    <button class="fk-icon-btn" id="fkSearchBtn" aria-label="Search"
                        style="border:none;cursor:pointer;background:transparent;">
                        <i class="fas fa-search"></i>
                    </button>
                    <% } %>

                        <!-- Notification -->
                        <button class="fk-icon-btn" id="fkNotifyBtn" aria-label="Notifications"
                            style="border:none;cursor:pointer;background:transparent;">
                            <i class="fas fa-bell"></i>
                            <% if (typeof NOtify !=='undefined' && NOtify && Array.isArray(NOtify.notification) &&
                                NOtify.notification.length> 0) { %>
                                <span class="fk-badge">
                                    <%= NOtify.notification.length %>
                                </span>
                                <% } %>
                        </button>

                <!-- Cart -->
                <a href="/cart" class="fk-icon-btn" aria-label="Cart">
                    <i class="fas fa-shopping-cart"></i>
                    <% if (typeof carSize !=='undefined' && carSize !==null && carSize> 0) { %>
                        <span class="fk-badge">
                            <%= carSize %>
                        </span>
                        <% } %>
                </a>

                <!-- Wishlist -->
                <a href="/wishList" class="fk-icon-btn" aria-label="Wishlist">
                    <i class="fas fa-heart"></i>
                    <% if (typeof size !=='undefined' && size> 0) { %>
                        <span class="fk-badge">
                            <%= size %>
                        </span>
                        <% } %>
                </a>

                <!-- Profile -->
                <% if (typeof user !=='undefined' && user) { %>
                    <a href="/profile/<%= user %>" class="fk-profile-btn">
                        <i class="fas fa-user-circle"></i> Account
                    </a>
                    <% } %>
            </div>
        </div>
    </nav>

