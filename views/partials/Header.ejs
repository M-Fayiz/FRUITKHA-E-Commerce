            <!-- ── Coupon Drawer ── -->
            <button class="fk-coupon-toggle" id="fkCouponToggle" title="View Coupons">
                <i class="fas fa-ticket-alt"></i>
                Coupons
            </button>

            <div class="fk-coupon-drawer" id="fkCouponDrawer">
                <div class="fk-coupon-header">
                    <h5><i class="fas fa-ticket-alt me-2" style="color:#F28123"></i>Available Coupons</h5>
                    <button class="fk-coupon-close" id="fkCouponClose"><i class="fas fa-times"></i></button>
                </div>
                <div class="fk-coupon-body">
                    <% if (typeof coupon !=='undefined' && coupon && coupon.length> 0) { %>
                        <% coupon.forEach(item=> { %>
                            <div class="fk-coupon-card">
                                <div class="fk-coupon-code"><i class="fas fa-tag me-2"></i>
                                    <%= item.code %>
                                </div>
                                <div class="fk-coupon-desc">
                                    <%= item.Description %>
                                </div>
                                <div class="fk-coupon-min"><i class="fas fa-shopping-cart me-1"></i>Min. purchase ₹<%=
                                        item.minCartValue %>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <p
                                        style="color:rgba(255,255,255,0.5);font-size:13px;font-family:'Poppins',sans-serif;text-align:center;padding:20px 0;">
                                        No coupons available right now.</p>
                                    <% } %>
                </div>
            </div>

            <div class="fk-notify-drawer" id="fkNotifyDrawer">
                <div class="fk-notify-header">
                    <h5><i class="fas fa-bell me-2" style="color:#F28123"></i>Notifications</h5>
                    <button class="fk-notify-close" id="fkNotifyClose"><i class="fas fa-times"></i></button>
                </div>
                <div class="fk-notify-body">
                    <% if (typeof NOtify !=='undefined' && NOtify && Array.isArray(NOtify.notification) &&
                        NOtify.notification.length> 0) { %>
                        <% NOtify.notification.sort((a, b)=> new Date(b.createdAt) - new Date(a.createdAt)).forEach(item => { %>
                            <div class="fk-notify-item <%= item.status || '' %>">
                                <p>
                                    <%= item.message %>
                                </p>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <p class="fk-notify-empty">No notifications available</p>
                                    <% } %>
                </div>
            </div>


            <% if (_cp !=='shop' ) { %>
                <div class="fk-search-overlay" id="fkSearchOverlay">
                    <div class="fk-search-box">
                        <i class="fas fa-search" style="color:#F28123;font-size:18px;"></i>
                        <input type="text" id="fkSearchInput" placeholder="Search for fruits, categories…">
                        <button
                            onclick="window.location='/shop?search='+document.getElementById('fkSearchInput').value">Search</button>
                    </div>
                    <button class="fk-search-close" id="fkSearchClose"><i class="fas fa-times"></i></button>
                </div>
                <% } %>

            <script>
                (function () {
                    const couponToggle = document.getElementById('fkCouponToggle');
                    const couponDrawer = document.getElementById('fkCouponDrawer');
                    const couponClose = document.getElementById('fkCouponClose');
                    const searchBtn = document.getElementById('fkSearchBtn');
                    const searchOverlay = document.getElementById('fkSearchOverlay');
                    const searchClose = document.getElementById('fkSearchClose');
                    const searchInput = document.getElementById('fkSearchInput');
                    const notifyBtn = document.getElementById('fkNotifyBtn');
                    const notifyDrawer = document.getElementById('fkNotifyDrawer');
                    const notifyClose = document.getElementById('fkNotifyClose');

                    if (couponToggle && couponDrawer) {
                        couponToggle.addEventListener('click', () => couponDrawer.classList.toggle('open'));
                        couponClose && couponClose.addEventListener('click', () => couponDrawer.classList.remove('open'));
                    }
                    if (searchBtn && searchOverlay) {
                        searchBtn.addEventListener('click', () => { searchOverlay.classList.add('open'); searchInput && searchInput.focus(); });
                        searchClose && searchClose.addEventListener('click', () => searchOverlay.classList.remove('open'));
                        searchOverlay.addEventListener('click', (e) => { if (e.target === searchOverlay) searchOverlay.classList.remove('open'); });
                        searchInput && searchInput.addEventListener('keydown', (e) => {
                            if (e.key === 'Enter') window.location = '/shop?search=' + encodeURIComponent(searchInput.value);
                            if (e.key === 'Escape') searchOverlay.classList.remove('open');
                        });
                    }
                    if (notifyBtn && notifyDrawer) {
                        notifyBtn.addEventListener('click', () => notifyDrawer.classList.toggle('open'));
                        notifyClose && notifyClose.addEventListener('click', () => notifyDrawer.classList.remove('open'));
                        document.addEventListener('click', (e) => {
                            if (!notifyDrawer.classList.contains('open')) return;
                            if (e.target.closest('#fkNotifyBtn') || e.target.closest('#fkNotifyDrawer')) return;
                            notifyDrawer.classList.remove('open');
                        });
                    }
                })();
            </script>
