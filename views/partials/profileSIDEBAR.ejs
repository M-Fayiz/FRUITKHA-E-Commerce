<% /* Determine the active page based on the URL for sidebar highlighting */ const currentPath=typeof locals.currentPath
    !=='undefined' ? locals.currentPath : '' ; %>
    <aside class="user-sidebar" id="userSidebar">

        <!-- User Avatar / Greeting -->
        <div class="sidebar-user-block">
            <div class="sidebar-avatar">
                <%= (user && user.firstName) ? user.firstName.charAt(0).toUpperCase() : 'U' %>
            </div>
            <p class="sidebar-username">
                <%= (user && user.firstName) ? user.firstName : 'User' %>
                    <%= (user && user.lastName) ? user.lastName : '' %>
            </p>
            <span class="sidebar-role">My Account</span>
        </div>

        <!-- Navigation Links -->
        <nav class="sidebar-nav">
            <a href="/" class="s-link">
                <i class="fas fa-home"></i>
                <span>Home</span>
            </a>

            <a href="/profile" class="s-link <%= currentPath === 'profile' ? 'active' : '' %>">
                <i class="fas fa-user"></i>
                <span>Profile</span>
            </a>

            <a href="/orderList" class="s-link <%= currentPath === 'orderList' ? 'active' : '' %>">
                <i class="fas fa-shopping-bag"></i>
                <span>My Orders</span>
            </a>

            <a href="/wishList" class="s-link <%= currentPath === 'wishList' ? 'active' : '' %>">
                <i class="fas fa-heart"></i>
                <span>Wishlist</span>
            </a>

            <a href="/cart" class="s-link <%= currentPath === 'cart' ? 'active' : '' %>">
                <i class="fas fa-shopping-cart"></i>
                <span>Cart</span>
            </a>

            <a href="/address" class="s-link <%= currentPath === 'address' ? 'active' : '' %>">
                <i class="fas fa-map-marker-alt"></i>
                <span>Addresses</span>
            </a>

            <a href="/wallet" class="s-link <%= currentPath === 'wallet' ? 'active' : '' %>">
                <i class="fas fa-wallet"></i>
                <span>Wallet</span>
            </a>

            <div class="sidebar-divider mt-auto"></div>

            <a href="/logOut" class="s-link s-logout">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
        </nav>

    </aside>
